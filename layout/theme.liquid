<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="{{ settings.colors_primary | default: '#1A365D' }}">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if template.name == 'cart'
      or template.name == 'search'
      or template.name == '404'
      or template.name == 'password'
      or template.directory == 'customers'
    -%}
      <meta name="robots" content="noindex, follow">
    {%- endif -%}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}
    {% render 'seo-jsonld' %}

    {{ content_for_header }}

    {{ 'font-faces.css' | asset_url | stylesheet_tag }}
    {% style %}
      :root {
        --font-body: {{ settings.type_body_font.family }}, {{ settings.type_body_font.fallback_families }};
        --font-heading: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
        --color-primary: {{ settings.colors_primary | default: '#1A365D' }};
        --color-bg: {{ settings.colors_background }};
        --color-surface: {{ settings.colors_surface }};
        --color-text: {{ settings.colors_text }};
        --color-muted: {{ settings.colors_muted }};
        --color-accent: {{ settings.colors_accent }};
        --color-button: {{ settings.colors_button }};
        --color-button-label: {{ settings.colors_button_label }};
        --font-body-weight: {{ settings.type_body_font.weight }};
        --font-heading-weight: {{ settings.type_heading_font.weight }};
      }
    {% endstyle %}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
  </head>
  <body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">
    <a class="skip-link visually-hidden-focusable" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>

    {% sections 'header-group' %}

    <main id="MainContent" class="main-content" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    <ul hidden>
      <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
    </ul>
  </body>
</html>
