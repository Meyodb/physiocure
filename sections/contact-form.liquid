<section class="section-padding">
  <div class="page-width" style="max-width: 36rem;">
    <header class="page-header">
      <h1>{{ section.settings.heading | default: page.title }}</h1>
      {%- if section.settings.intro != blank -%}
        <p style="color: var(--color-muted);">{{ section.settings.intro }}</p>
      {%- endif -%}
    </header>

    {% form 'contact' %}
      {%- if form.posted_successfully? -%}
        <p style="color: var(--color-primary); font-weight:600;">{{ 'contact.form.post_success' | t }}</p>
      {%- else -%}
        {{ form.errors | default_errors }}
        <div class="field">
          <label for="ContactName">{{ 'contact.form.name' | t }}</label>
          <input type="text" id="ContactName" name="contact[name]" value="{{ form.name }}" autocomplete="name" required>
        </div>
        <div class="field">
          <label for="ContactEmail">{{ 'contact.form.email' | t }}</label>
          <input type="email" id="ContactEmail" name="contact[email]" value="{{ form.email }}" autocomplete="email" required>
        </div>
        <div class="field">
          <label for="ContactPhone">{{ 'contact.form.phone' | t }}</label>
          <input type="tel" id="ContactPhone" name="contact[phone]" value="{{ form.phone }}" autocomplete="tel">
        </div>
        <div class="field">
          <label for="ContactBody">{{ 'contact.form.comment' | t }}</label>
          <textarea id="ContactBody" name="contact[body]" rows="6" required>{{ form.body }}</textarea>
        </div>
        <button type="submit" class="btn">{{ 'contact.form.send' | t }}</button>
      {%- endif -%}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Formulaire de contact",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Nous écrire"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Introduction",
      "default": "Une question sur le produit, la livraison ou votre commande ? Notre équipe vous répond rapidement."
    }
  ],
  "presets": [{ "name": "Formulaire de contact" }]
}
{% endschema %}
