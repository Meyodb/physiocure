<footer class="site-footer" role="contentinfo">
  <div class="site-footer__main page-width">
    <div class="site-footer__brand">
      <p class="footer-eyebrow">{{ shop.name }}</p>
      <p class="site-footer__bio">
        {{ section.settings.bio | default: "Soins du pied et récupération au quotidien. Conçu pour le confort durable, sans compromis sur la qualité." }}
      </p>
      {%- liquid
        assign has_social = false
        if settings.social_instagram != blank or settings.social_facebook != blank or settings.social_youtube != blank
          assign has_social = true
        endif
      -%}
      {%- if has_social -%}
        <ul class="footer-social" role="list">
          {%- if settings.social_instagram != blank -%}
            <li>
              <a
                href="{{ settings.social_instagram }}"
                class="footer-social__link"
                rel="noopener noreferrer"
                target="_blank"
                aria-label="Instagram"
              >
                <span class="visually-hidden">Instagram</span>
                <svg class="footer-social__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path fill="currentColor" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                </svg>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <li>
              <a
                href="{{ settings.social_facebook }}"
                class="footer-social__link"
                rel="noopener noreferrer"
                target="_blank"
                aria-label="Facebook"
              >
                <span class="visually-hidden">Facebook</span>
                <svg class="footer-social__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path fill="currentColor" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            </li>
          {%- endif -%}
          {%- if settings.social_youtube != blank -%}
            <li>
              <a
                href="{{ settings.social_youtube }}"
                class="footer-social__link"
                rel="noopener noreferrer"
                target="_blank"
                aria-label="YouTube"
              >
                <span class="visually-hidden">YouTube</span>
                <svg class="footer-social__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path fill="currentColor" d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            </li>
          {%- endif -%}
        </ul>
      {%- endif -%}
    </div>

    {%- comment -%}
      Liens « légaux » du menu : type policy, URL /policies/, ou titres habituels (FR).
      Affichés uniquement sous « Informations légales », pas sous « Navigation ».
    {%- endcomment -%}
    <div class="site-footer__columns">
      <div class="site-footer__block">
        <p class="footer-eyebrow" id="footer-nav-heading">Navigation</p>
        <nav class="footer-nav" aria-labelledby="footer-nav-heading">
          <ul class="footer-nav__list" role="list">
            <li><a href="{{ routes.root_url }}">Accueil</a></li>
            <li><a href="{{ routes.all_products_collection_url }}">Produits</a></li>
            {%- if section.settings.menu_footer != blank -%}
              {%- for link in section.settings.menu_footer.links -%}
                {%- liquid
                  assign lt = link.title | downcase
                  assign is_legal_link = false
                  if link.type == 'policy'
                    assign is_legal_link = true
                  endif
                  if link.url contains '/policies/'
                    assign is_legal_link = true
                  endif
                  if lt contains 'remboursement' or lt contains 'confidentialit' or lt contains 'cgv' or lt contains 'conditions' and lt contains 'générales' or lt contains 'conditions' and lt contains 'generales' or lt contains 'mentions légales' or lt contains 'mentions legales' or lt contains 'mention légale' or lt contains 'mention legale' or lt contains 'politique de cookies'
                    assign is_legal_link = true
                  endif
                -%}
                {%- unless is_legal_link -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endunless -%}
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </nav>
      </div>

      <div class="site-footer__block">
        <p class="footer-eyebrow" id="footer-legal-heading">Informations légales</p>
        <nav class="footer-nav" aria-labelledby="footer-legal-heading">
          <ul class="footer-nav__list" role="list">
            {%- liquid
              assign seen_legal_urls = '|'
            -%}
            {%- if shop.policies.refund_policy != blank -%}
              {%- assign u = shop.policies.refund_policy.url -%}
              <li><a href="{{ u }}">{{ shop.policies.refund_policy.title }}</a></li>
              {%- assign seen_legal_urls = seen_legal_urls | append: u | append: '|' -%}
            {%- endif -%}
            {%- if shop.policies.shipping_policy != blank -%}
              {%- assign u = shop.policies.shipping_policy.url -%}
              <li><a href="{{ u }}">{{ shop.policies.shipping_policy.title }}</a></li>
              {%- assign seen_legal_urls = seen_legal_urls | append: u | append: '|' -%}
            {%- endif -%}
            {%- if shop.policies.privacy_policy != blank -%}
              {%- assign u = shop.policies.privacy_policy.url -%}
              <li><a href="{{ u }}">{{ shop.policies.privacy_policy.title }}</a></li>
              {%- assign seen_legal_urls = seen_legal_urls | append: u | append: '|' -%}
            {%- endif -%}
            {%- if shop.policies.terms_of_service != blank -%}
              {%- assign u = shop.policies.terms_of_service.url -%}
              <li><a href="{{ u }}">{{ shop.policies.terms_of_service.title }}</a></li>
              {%- assign seen_legal_urls = seen_legal_urls | append: u | append: '|' -%}
            {%- endif -%}
            {%- if shop.policies.legal_notice != blank -%}
              {%- assign u = shop.policies.legal_notice.url -%}
              <li><a href="{{ u }}">{{ shop.policies.legal_notice.title }}</a></li>
              {%- assign seen_legal_urls = seen_legal_urls | append: u | append: '|' -%}
            {%- endif -%}
            {%- if section.settings.menu_footer != blank -%}
              {%- for link in section.settings.menu_footer.links -%}
                {%- liquid
                  assign lt = link.title | downcase
                  assign is_legal_link = false
                  if link.type == 'policy'
                    assign is_legal_link = true
                  endif
                  if link.url contains '/policies/'
                    assign is_legal_link = true
                  endif
                  if lt contains 'remboursement' or lt contains 'confidentialit' or lt contains 'cgv' or lt contains 'conditions' and lt contains 'générales' or lt contains 'conditions' and lt contains 'generales' or lt contains 'mentions légales' or lt contains 'mentions legales' or lt contains 'mention légale' or lt contains 'mention legale' or lt contains 'politique de cookies'
                    assign is_legal_link = true
                  endif
                  assign needle = link.url | prepend: '|' | append: '|'
                  assign seen = false
                  if seen_legal_urls contains needle
                    assign seen = true
                  endif
                -%}
                {%- if is_legal_link and seen == false -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- assign seen_legal_urls = seen_legal_urls | append: link.url | append: '|' -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          </ul>
        </nav>
      </div>

      <div class="site-footer__block site-footer__block--trust">
        <p class="footer-eyebrow" id="footer-trust-heading">Confiance</p>
        {%- assign trust_html = section.settings.trust_points | newline_to_br | split: '<br />' -%}
        {%- assign trust_has_content = false -%}
        {%- for line in trust_html -%}
          {%- assign t = line | strip | strip_html -%}
          {%- if t != '' -%}
            {%- assign trust_has_content = true -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if trust_has_content -%}
          <ul class="footer-trust" role="list" aria-labelledby="footer-trust-heading">
            {%- for line in trust_html -%}
              {%- assign t = line | strip | strip_html -%}
              {%- if t != '' -%}
                <li class="footer-trust__item">
                  <span class="footer-trust__dot" aria-hidden="true"></span>
                  <span>{{ t }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- else -%}
          <p class="site-footer__trust-fallback">
            Paiement sécurisé, politiques transparentes — retrouvez les détails dans la colonne « Informations légales ».
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="site-footer__bar page-width">
    <p class="site-footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.legal_note }}
    </p>
    <div class="site-footer__payments" role="group" aria-label="Modes de paiement acceptés">
      <span class="payment-pill">Visa</span>
      <span class="payment-pill">Mastercard</span>
      <span class="payment-pill">Amex</span>
      <span class="payment-pill">PayPal</span>
      <span class="payment-pill">Apple Pay</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Pied de page",
  "class": "section-footer",
  "settings": [
    {
      "type": "textarea",
      "id": "bio",
      "label": "Texte de présentation courte"
    },
    {
      "type": "link_list",
      "id": "menu_footer",
      "label": "Menu pied de page",
      "info": "Contact, à propos, etc. Les entrées reconnues comme légales (politiques Shopify, URL /policies/, titres CGV, confidentialité, mentions légales…) s’affichent dans la colonne Informations légales, pas ici."
    },
    {
      "type": "textarea",
      "id": "trust_points",
      "label": "Points confiance",
      "default": "Paiement 100 % sécurisé\nExpédition soignée\nService client à votre écoute",
      "info": "Une ligne par point. S’affiche dans la colonne Confiance."
    },
    {
      "type": "text",
      "id": "legal_note",
      "label": "Mention légale courte",
      "default": "Tous droits réservés."
    }
  ]
}
{% endschema %}
