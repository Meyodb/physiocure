{%- liquid
  assign ann_seconds = section.settings.announcement_marquee_seconds | default: 30 | plus: 0
  if ann_seconds < 12
    assign ann_seconds = 45
  elsif ann_seconds > 90
    assign ann_seconds = 90
  endif
-%}
{%- if section.settings.show_announcement and section.settings.announcement_text != blank -%}
  <div
    class="header-announcement"
    role="region"
    aria-label="{{ 'sections.header.announcement' | t }}"
    style="--header-announcement-duration: {{ ann_seconds }}s;"
  >
    <div class="header-announcement__viewport">
      <div class="header-announcement__track">
        <span class="header-announcement__segment">{{ section.settings.announcement_text }}</span>
        <span class="header-announcement__segment" aria-hidden="true">{{ section.settings.announcement_text }}</span>
      </div>
    </div>
  </div>
{%- endif -%}

<header class="site-header" data-header role="banner">
  <div class="header-inner page-width" style="width:min(100% - 2rem, 72rem); margin-inline:auto;">
    <a href="{{ routes.root_url }}" class="header-logo">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 800 }}"
          alt="{{ shop.name | escape }}"
          width="{{ section.settings.logo.width }}"
          height="{{ section.settings.logo.height }}"
          loading="eager"
          decoding="async"
        >
      {%- else -%}
        <img
          src="{{ 'logo-physiocure.png' | asset_url }}"
          alt="{{ section.settings.logo_text | default: 'PhysioCure' | escape }}"
          width="697"
          height="314"
          loading="eager"
          decoding="async"
        >
      {%- endif -%}
    </a>

    <button
      type="button"
      class="menu-toggle"
      aria-expanded="false"
      aria-controls="MainNav"
      data-menu-toggle
    >
      <span class="visually-hidden">{{ 'accessibility.menu' | t }}</span>
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <nav id="MainNav" class="main-nav" data-main-nav aria-label="Principal">
      {%- if section.settings.menu != blank -%}
        {%- assign suivi_commande_nav_title = 'Suivre ma commande' -%}
        {%- assign suivi_commande_link = false -%}
        {%- for link in section.settings.menu.links -%}
          {%- if link.title == 'Suivi de commande' or link.title == suivi_commande_nav_title -%}
            {%- assign suivi_commande_link = link -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        {%- assign suivi_commande_shown = false -%}
        {%- for link in section.settings.menu.links -%}
          {%- liquid
            assign hide_suivi = false
            if link.title == 'Suivi'
              assign hide_suivi = true
            endif
            if link.type == 'page' and link.object != blank and link.object.handle == 'suivi'
              assign hide_suivi = true
            endif

            assign skip_suivi_commande = false
            if suivi_commande_link
              if link.title == 'Suivi de commande' or link.title == suivi_commande_nav_title
                assign skip_suivi_commande = true
              endif
            endif
          -%}
          {%- unless hide_suivi or skip_suivi_commande -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endunless -%}
          {%- if link.title == 'PhysioCure' and suivi_commande_link -%}
            <a href="{{ suivi_commande_link.url }}">{{ suivi_commande_nav_title }}</a>
            {%- assign suivi_commande_shown = true -%}
          {%- endif -%}
        {%- endfor -%}
        {%- if suivi_commande_link and suivi_commande_shown == false -%}
          <a href="{{ suivi_commande_link.url }}">{{ suivi_commande_nav_title }}</a>
        {%- endif -%}
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}">{{ 'collections.title' | t }}</a>
        <a href="{{ pages.contact.url | default: '#' }}">Contact</a>
      {%- endif -%}
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "En-tête",
  "class": "section-header",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Afficher la bandeau d'annonce",
      "default": true
    },
    {
      "type": "textarea",
      "id": "announcement_text",
      "label": "Texte d'annonce",
      "default": "📦 Expédition suivie — Votre colis, du départ à la livraison · 🔒 Paiement sécurisé — Cryptage SSL & transactions protégées · 💬 SAV réactif — Une réponse sous 48 h ouvrées · 🛡️ Transparence totale — Retours simples, politique claire",
      "info": "Aligné sur le bandeau confiance de la page d’accueil. Dupliqué automatiquement pour le défilement."
    },
    {
      "type": "range",
      "id": "announcement_marquee_seconds",
      "min": 15,
      "max": 90,
      "step": 5,
      "unit": "s",
      "label": "Durée d'un cycle de défilement",
      "default": 45
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Texte du logo (si pas d'image)",
      "default": "PhysioCure"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
