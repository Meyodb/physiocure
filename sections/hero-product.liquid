{%- assign featured = section.settings.product -%}
<section class="section-padding" style="padding-top: clamp(2rem, 5vw, 3.5rem);">
  <div class="page-width">
    <div class="grid-2">
      <div>
        <div style="border-radius: 20px; overflow: hidden; background: var(--color-surface); border: 1px solid rgba(0,0,0,0.06); box-shadow: 0 24px 60px rgba(0,0,0,0.08);">
          {%- liquid
            assign hero_alt = section.settings.hero_alt | default: section.settings.heading | default: 'Femme détendue dans un salon lumineux, appareil de bien-être pour les jambes'
          -%}
          {%- if section.settings.hero_image != blank -%}
            {{
              section.settings.hero_image
              | image_url: width: 1200
              | image_tag:
                loading: 'eager',
                sizes: '(min-width: 900px) 50vw, 100vw',
                widths: '400, 600, 800, 1000, 1200',
                alt: section.settings.hero_image.alt | default: hero_alt
            }}
          {%- else -%}
            <img
              src="{{ 'physiocure-home-hero.png' | asset_url }}"
              alt="{{ hero_alt | escape }}"
              loading="eager"
              decoding="async"
              width="650"
              height="582"
              sizes="(min-width: 900px) 50vw, 100vw"
              style="width: 100%; height: auto; display: block;"
            >
          {%- endif -%}
        </div>
      </div>
      <div>
        {%- if section.settings.badge != blank -%}
          <span class="badge">{{ section.settings.badge }}</span>
        {%- endif -%}
        <h1 style="font-size: clamp(2rem, 5vw, 3rem); margin-top: 0.75rem;">
          {{ section.settings.heading | default: featured.title | default: "Retrouvez la légèreté de vos jambes en 15 minutes." }}
        </h1>
        <p style="font-size: 1.1rem; color: var(--color-muted); max-width: 36rem;">
          {{ section.settings.subheading }}
        </p>

        {%- liquid
          if featured != blank
            assign primary_href = featured.url
          elsif collections.all != blank and collections.all.products_count > 0
            assign primary_href = collections.all.products.first.url
          elsif section.settings.primary_cta_page != blank
            assign primary_href = section.settings.primary_cta_page.url
          elsif pages.physiocure != blank
            assign primary_href = pages.physiocure.url
          else
            assign primary_href = routes.all_products_collection_url
          endif
        -%}

        {%- if featured != blank -%}
          <div style="margin: 1.5rem 0;">
            {% render 'price', product: featured %}
          </div>

          <div style="display:flex; flex-wrap:wrap; gap:0.75rem; align-items:center;">
            <a href="{{ primary_href }}" class="btn">{{ section.settings.primary_cta_label }}</a>
            <a href="{{ featured.url }}#MainProduct" class="btn btn--secondary">{{ section.settings.secondary_cta_label }}</a>
          </div>
        {%- else -%}
          <a href="{{ primary_href }}" class="btn">{{ section.settings.primary_cta_label }}</a>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul style="margin: 2rem 0 0; padding: 0; list-style: none; display: grid; gap: 0.75rem;">
            {%- for block in section.blocks -%}
              <li style="display:flex; gap:0.65rem; align-items:flex-start;" {{ block.shopify_attributes }}>
                <span style="color: var(--color-accent); font-weight:700;">✓</span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero produit",
  "tag": "section",
  "class": "section-hero-product",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image hero",
      "info": "Optionnel : remplace la photo d’accueil lifestyle incluse dans le thème."
    },
    {
      "type": "text",
      "id": "hero_alt",
      "label": "Texte alternatif de l’image (accessibilité)",
      "default": "Femme détendue dans un salon lumineux, appareil de bien-être pour les jambes"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Produit vedette"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Bien-être & récupération"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre (optionnel)",
      "info": "Laissez vide pour utiliser le nom du produit"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Soulagez la sensation de jambes lourdes et retrouvez la légèreté — quelques minutes par jour, confortablement installé chez vous."
    },
    {
      "type": "page",
      "id": "primary_cta_page",
      "label": "Page du bouton principal",
      "info": "Utilisé seulement s’il n’y a ni produit vedette ni produit dans le catalogue « Tous les produits ». Sinon le bouton mène d’abord à une fiche produit."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Libellé bouton principal",
      "default": "Soulager mes jambes maintenant",
      "info": "Mène à la fiche du produit vedette, ou à la première fiche du catalogue « Tous les produits » si le vedette n’est pas défini — pas à la liste des produits."
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Libellé bouton secondaire",
      "default": "Voir les détails",
      "info": "Même fiche produit, avec défilement vers la zone d’achat (#MainProduct)."
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point fort",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Programmes de massage ciblés pieds et voûte plantaire"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero produit",
      "blocks": [
        { "type": "point", "settings": { "text": "15 niveaux d’intensité pour un drainage sur-mesure." } },
        { "type": "point", "settings": { "text": "Technologie de chaleur apaisante pour relancer le flux sanguin." } },
        { "type": "point", "settings": { "text": "Soulagement garanti : 90 jours pour tester sans risque." } }
      ]
    }
  ]
}
{% endschema %}
