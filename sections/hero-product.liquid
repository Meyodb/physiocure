{%- assign featured = section.settings.product -%}
<section class="section-padding" style="padding-top: clamp(2rem, 5vw, 3.5rem);">
  <div class="page-width">
    <div class="grid-2">
      <div>
        {%- if featured != blank -%}
          <div style="border-radius: 20px; overflow: hidden; background: var(--color-surface); border: 1px solid rgba(0,0,0,0.06); box-shadow: 0 24px 60px rgba(0,0,0,0.08);">
            {%- if featured.featured_media -%}
              {%- assign hero_alt = featured.featured_media.alt | default: featured.title -%}
              {{
                featured.featured_media
                | image_url: width: 1200
                | image_tag:
                  loading: 'eager',
                  sizes: '(min-width: 900px) 50vw, 100vw',
                  widths: '400, 600, 800, 1000, 1200',
                  alt: hero_alt
              }}
            {%- endif -%}
          </div>
        {%- else -%}
          <div style="aspect-ratio:1; border-radius:20px; background: linear-gradient(145deg, #EDF2F7, #F7FAFC); display:flex; align-items:center; justify-content:center; color: var(--color-muted);">
            <span style="padding:1rem; text-align:center;">Sélectionnez votre produit vedette dans l’éditeur de thème (section Hero produit).</span>
          </div>
        {%- endif -%}
      </div>
      <div>
        {%- if section.settings.badge != blank -%}
          <span class="badge">{{ section.settings.badge }}</span>
        {%- endif -%}
        <h1 style="font-size: clamp(2rem, 5vw, 3rem); margin-top: 0.75rem;">
          {{ section.settings.heading | default: featured.title | default: "Masseur de pieds premium" }}
        </h1>
        <p style="font-size: 1.1rem; color: var(--color-muted); max-width: 36rem;">
          {{ section.settings.subheading }}
        </p>

        {%- if featured != blank -%}
          <div style="margin: 1.5rem 0;">
            {% render 'price', product: featured %}
          </div>

          {%- if featured.has_only_default_variant -%}
            {% form 'product', featured, class: 'hero-product-form', style: 'display:flex; flex-wrap:wrap; gap:0.75rem; align-items:center;' %}
              <input type="hidden" name="id" value="{{ featured.selected_or_first_available_variant.id }}">
              <button type="submit" name="add" class="btn" {% unless featured.available %}disabled{% endunless %}>
                {%- if featured.available -%}
                  {{ 'products.product.add_to_cart' | t }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t }}
                {%- endif -%}
              </button>
              <a href="{{ featured.url }}" class="btn btn--secondary">{{ section.settings.secondary_cta_label }}</a>
            {% endform %}
          {%- else -%}
            <div style="display:flex; flex-wrap:wrap; gap:0.75rem;">
              <a href="{{ featured.url }}" class="btn">{{ section.settings.primary_cta_label }}</a>
              <a href="{{ featured.url }}#MainProduct" class="btn btn--secondary">{{ section.settings.secondary_cta_label }}</a>
            </div>
          {%- endif -%}
        {%- else -%}
          <a href="{{ routes.all_products_collection_url }}" class="btn">{{ section.settings.primary_cta_label }}</a>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul style="margin: 2rem 0 0; padding: 0; list-style: none; display: grid; gap: 0.75rem;">
            {%- for block in section.blocks -%}
              <li style="display:flex; gap:0.65rem; align-items:flex-start;" {{ block.shopify_attributes }}>
                <span style="color: var(--color-accent); font-weight:700;">✓</span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero produit",
  "tag": "section",
  "class": "section-hero-product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Produit vedette"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Bien-être & récupération"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre (optionnel)",
      "info": "Laissez vide pour utiliser le nom du produit"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Soulagez la tension plantaire et retrouvez une sensation de légèreté après la journée. Design pensé pour un usage quotidien, finitions soignées et expérience de marque transparente."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Libellé bouton principal",
      "default": "Découvrir le produit"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Libellé bouton secondaire",
      "default": "Voir les détails"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point fort",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "Programmes de massage ciblés pieds et voûte plantaire"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero produit",
      "blocks": [
        { "type": "point", "settings": { "text": "Pressions ajustables pour un confort personnalisé" } },
        { "type": "point", "settings": { "text": "Chaleur douce en option pour détendre les muscles" } },
        { "type": "point", "settings": { "text": "Livraison suivie et emballage soigné" } }
      ]
    }
  ]
}
{% endschema %}
