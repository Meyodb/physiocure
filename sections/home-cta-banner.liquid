<section
  class="section-home-cta-banner{% if section.settings.image != blank %} section-home-cta-banner--has-bg{% endif %}"
  aria-labelledby="home-cta-heading-{{ section.id }}"
>
  <div class="section-home-cta-banner__bg" aria-hidden="true">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1600
        | image_tag:
          loading: 'lazy',
          sizes: '100vw',
          widths: '800, 1200, 1600',
          class: 'section-home-cta-banner__bg-img',
          alt: ''
      }}
    {%- endif -%}
  </div>
  <div class="page-width section-home-cta-banner__inner">
    <div class="section-home-cta-banner__card">
      {%- if section.settings.heading != blank -%}
        <h2 id="home-cta-heading-{{ section.id }}" style="font-size: clamp(1.4rem, 3vw, 1.85rem); margin: 0 0 0.65rem;">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p style="margin: 0 0 1.25rem; color: var(--color-muted); max-width: 32rem;">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- liquid
        assign btn_href = section.settings.button_link
        if btn_href == blank and section.settings.button_page != blank
          assign btn_href = section.settings.button_page.url
        endif
        if btn_href == blank
          assign btn_href = routes.all_products_collection_url
        endif
      -%}
      <a href="{{ btn_href }}" class="btn">{{ section.settings.button_label }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bandeau CTA accueil",
  "tag": "section",
  "class": "section-home-cta-banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Prêt à soulager vos jambes ?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte",
      "default": "Livraison suivie, SAV réactif et politique de retour claire — commandez en toute confiance."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Libellé du bouton",
      "default": "Voir les produits"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton",
      "info": "Prioritaire sur la page ci-dessous."
    },
    {
      "type": "page",
      "id": "button_page",
      "label": "Page du bouton (si pas de lien)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image de fond (optionnelle)",
      "info": "Texture ou photo discrète ; le texte reste lisible sur un voile."
    }
  ],
  "presets": [
    {
      "name": "Bandeau CTA accueil"
    }
  ]
}
{% endschema %}
