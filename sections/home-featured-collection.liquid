{%- assign coll = section.settings.collection -%}
<section
  class="section-padding section-home-featured-collection"
  style="background: var(--color-surface); border-block: 1px solid rgba(0,0,0,0.06);"
  aria-labelledby="home-featured-heading-{{ section.id }}"
>
  <div class="page-width">
    <header class="home-section-header" style="text-align: center; max-width: 40rem; margin: 0 auto clamp(1.5rem, 4vw, 2.25rem);">
      {%- if section.settings.eyebrow != blank -%}
        <p class="home-section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 id="home-featured-heading-{{ section.id }}" style="font-size: clamp(1.5rem, 3vw, 2.1rem); margin: 0 0 0.75rem;">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p style="margin: 0; color: var(--color-muted); font-size: 1.05rem;">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    {%- if coll != blank and coll.products_count > 0 -%}
      <ul class="collection-grid collection-grid--home collection-grid--home-balanced" role="list">
        {%- for product in coll.products limit: section.settings.products_to_show -%}
          <li>
            <article class="card-product">
              <a href="{{ product.url }}" class="card-product__media">
                {%- if product.featured_media -%}
                  {%- assign card_alt = product.featured_media.alt | default: product.title -%}
                  {{
                    product.featured_media
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      decoding: 'async',
                      sizes: '(min-width: 900px) min(22rem, 28vw), min(92vw, 24rem)',
                      widths: '240, 360, 480, 600',
                      alt: card_alt
                  }}
                {%- endif -%}
              </a>
              <div class="card-product__info">
                <h3 class="card-product__title">
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                {% render 'price', product: product %}
              </div>
            </article>
          </li>
        {%- endfor -%}
      </ul>
      {%- if section.settings.show_view_all and coll.all_products_count > section.settings.products_to_show -%}
        <p style="text-align: center; margin-top: 2rem;">
          <a href="{{ coll.url }}" class="btn btn--secondary">{{ section.settings.view_all_label }}</a>
        </p>
      {%- endif -%}
    {%- else -%}
      <p style="text-align: center; color: var(--color-muted); max-width: 28rem; margin: 0 auto;">
        {{ section.settings.empty_state | default: 'Choisissez une collection dans les paramètres de cette section pour afficher vos produits.' }}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Vedette accueil",
  "tag": "section",
  "class": "section-home-featured-collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Surtitre",
      "default": "Notre sélection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Produits pour votre bien-être au quotidien"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Des solutions pensées pour la récupération, le confort des jambes et des pieds — qualité et simplicité d’usage."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection à afficher"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 2,
      "label": "Nombre de produits"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Afficher le lien « Voir tout »",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Libellé du lien",
      "default": "Voir toute la gamme"
    },
    {
      "type": "text",
      "id": "empty_state",
      "label": "Message si aucune collection",
      "default": "Choisissez une collection dans les paramètres de cette section pour afficher vos produits."
    }
  ],
  "presets": [
    {
      "name": "Vedette accueil"
    }
  ]
}
{% endschema %}
