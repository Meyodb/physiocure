{%- liquid
  assign visual_blocks = section.blocks | where: 'type', 'visual_howto_step'
-%}
<section
  class="section-padding section-home-howto-visual"
  {% if visual_blocks.size > 0 -%}
    aria-labelledby="HowToHeading-{{ section.id }}"
  {%- else -%}
    aria-label="Étapes d’utilisation"
  {%- endif %}
>
  <div class="page-width">
    {%- if visual_blocks.size > 0 -%}
      {% render 'howto-visual-steps',
        heading: section.settings.heading,
        blocks: visual_blocks,
        section_id: section.id,
        fallback_ext: section.settings.fallback_ext,
        embedded: false,
        root_tag: 'div'
      %}
    {%- else -%}
      <p class="section-home-howto-visual__empty">
        Ajoutez des blocs « Étape visuelle » dans l’éditeur de thème (ou des images howto-step-1…3 dans les fichiers du thème).
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "3 étapes visuelles (accueil)",
  "tag": "section",
  "class": "section-home-howto-visual",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "3 étapes pour soulager les jambes lourdes et retrouver la légèreté."
    },
    {
      "type": "select",
      "id": "fallback_ext",
      "label": "Images par défaut (si aucune image dans le bloc)",
      "options": [
        { "value": "png", "label": "PNG — howto-step-1.png, -2, -3" },
        { "value": "gif", "label": "GIF — howto-step-1.gif, -2, -3" }
      ],
      "default": "gif",
      "info": "Fichiers dans le dossier assets du thème."
    }
  ],
  "blocks": [
    {
      "type": "visual_howto_step",
      "name": "Étape visuelle",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image ou GIF",
          "info": "GIF : l’animation est conservée. Si vide : fichiers howto-step-1…3 dans assets/."
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Texte alternatif",
          "default": "Étape d’utilisation du produit"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Enroulez autour de la jambe"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Placez l’appareil autour du mollet et de la cheville, puis ajustez les sangles pour un maintien ferme et confortable.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "3 étapes visuelles",
      "blocks": [
        {
          "type": "visual_howto_step",
          "settings": {
            "image_alt": "Pose du bandage autour du mollet et de la cheville",
            "title": "Enroulez autour de la jambe",
            "text": "<p>Placez l’appareil autour du mollet et de la cheville, puis ajustez les sangles pour un maintien ferme et confortable.</p>"
          }
        },
        {
          "type": "visual_howto_step",
          "settings": {
            "image_alt": "Réglage du boîtier de contrôle",
            "title": "Choisissez vos réglages",
            "text": "<p>Utilisez le panneau pour choisir l’une des 15 intensités et activer la chaleur apaisante selon votre confort.</p>"
          }
        },
        {
          "type": "visual_howto_step",
          "settings": {
            "image_alt": "Utilisation détendue à la maison",
            "title": "Asseyez-vous et détendez-vous",
            "text": "<p>En environ 15 minutes, la combinaison drainage, massage et chaleur peut soulager la sensation de jambes lourdes — installé confortablement chez vous.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
