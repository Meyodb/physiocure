<section class="section-padding section-home-image-slots" style="background: var(--color-bg);">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="home-section-header" style="text-align: center; font-size: clamp(1.45rem, 3vw, 2rem); margin: 0 0 0.5rem;">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p style="text-align: center; color: var(--color-muted); max-width: 36rem; margin: 0 auto 2.25rem; font-size: 1.02rem;">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    <ul class="home-image-slots__grid" role="list">
      {%- for block in section.blocks -%}
        <li {{ block.shopify_attributes }}>
          <figure class="home-image-slots__card">
            <div class="home-image-slots__frame">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 900
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 900px) min(30vw, 400px), 92vw',
                    widths: '400, 600, 900',
                    alt: block.settings.image.alt | default: block.settings.caption
                }}
              {%- else -%}
                {% render 'home-image-placeholder', label: block.settings.placeholder_label, ratio: '4 / 3' %}
              {%- endif -%}
            </div>
            {%- if block.settings.caption != blank -%}
              <figcaption class="home-image-slots__caption">{{ block.settings.caption }}</figcaption>
            {%- endif -%}
          </figure>
        </li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Galerie images accueil",
  "tag": "section",
  "class": "section-home-image-slots",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "En images"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "Ajoutez vos photos (usage, détails, ambiance) depuis l’éditeur de thème — chaque bloc est un emplacement."
    }
  ],
  "blocks": [
    {
      "type": "slot",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "placeholder_label",
          "label": "Texte emplacement vide",
          "default": "Glissez une image ici"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Légende",
          "default": "Légende photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Galerie images accueil",
      "blocks": [
        { "type": "slot", "settings": { "placeholder_label": "Photo 1 — ambiance", "caption": "" } },
        { "type": "slot", "settings": { "placeholder_label": "Photo 2 — détail produit", "caption": "" } },
        { "type": "slot", "settings": { "placeholder_label": "Photo 3 — en situation", "caption": "" } }
      ]
    }
  ]
}
{% endschema %}
