<section class="section-padding">
  <div class="page-width" style="text-align:center; max-width: 36rem;">
    <h1 style="font-size: clamp(2rem, 5vw, 2.75rem);">{{ 'templates.404.title' | t }}</h1>
    <p style="color: var(--color-muted);">{{ 'templates.404.subtext' | t }}</p>
    <a href="{{ routes.root_url }}" class="btn" style="margin-top:1.5rem;">{{ 'general.continue_shopping' | t }}</a>
  </div>
</section>

{% schema %}
{
  "name": "404",
  "tag": "section",
  "class": "section-main-404"
}
{% endschema %}
