<section class="section-padding">
  <div class="page-width" style="max-width: 42rem;">
    <article>
      <header class="page-header">
        <p style="margin:0 0 0.5rem; font-size:0.9rem; color: var(--color-muted);">
          <a href="{{ blog.url }}">{{ blog.title }}</a>
        </p>
        <h1>{{ article.title }}</h1>
        <p style="font-size:0.9rem; color: var(--color-muted);">{{ article.published_at | date: format: 'abbreviated_date' }}</p>
      </header>

      {%- if article.image -%}
        {%- assign article_img_alt = article.image.alt | default: article.title -%}
        <div style="border-radius:14px; overflow:hidden; margin-bottom:2rem;">
          {{ article.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: article_img_alt }}
        </div>
      {%- endif -%}

      <div class="rte">
        {{ article.content }}
      </div>

      {%- if blog.comments_enabled? -%}
        <div style="margin-top:3rem; padding-top:2rem; border-top:1px solid rgba(0,0,0,0.08);">
          <h2 id="comments">{{ 'blogs.article.comments' | t: count: article.comments_count }}</h2>
          {% paginate article.comments by 20 %}
            {%- for comment in article.comments -%}
              <div style="padding:1rem 0; border-bottom:1px solid rgba(0,0,0,0.06);">
                <p style="margin:0; font-weight:600;">{{ comment.author }}</p>
                <p style="margin:0.25rem 0 0; font-size:0.85rem; color: var(--color-muted);">{{ comment.created_at | date: format: 'abbreviated_date' }}</p>
                <div class="rte" style="margin-top:0.5rem;">{{ comment.content }}</div>
              </div>
            {%- endfor -%}
          {% endpaginate %}

          {% form 'new_comment', article %}
            <h3 style="margin-top:2rem;">{{ 'blogs.article.comment_form_title' | t }}</h3>
            {{ form.errors | default_errors }}
            <div class="field">
              <label for="CommentAuthor">{{ 'blogs.article.name' | t }}</label>
              <input type="text" name="comment[author]" id="CommentAuthor" value="{{ form.author }}" required>
            </div>
            <div class="field">
              <label for="CommentEmail">{{ 'blogs.article.email' | t }}</label>
              <input type="email" name="comment[email]" id="CommentEmail" value="{{ form.email }}" required>
            </div>
            <div class="field">
              <label for="CommentBody">{{ 'blogs.article.message' | t }}</label>
              <textarea name="comment[body]" id="CommentBody" rows="5" required>{{ form.body }}</textarea>
            </div>
            <button type="submit" class="btn">{{ 'blogs.article.post' | t }}</button>
          {% endform %}
        </div>
      {%- endif -%}
    </article>
  </div>
</section>

{%- assign article_canonical = request.origin | append: article.url -%}
{%- assign article_ld_image = '' -%}
{%- if article.image -%}
  {%- assign article_ld_image = article.image | image_url: width: 1200 -%}
  {%- if article_ld_image contains '//' -%}
    {%- unless article_ld_image contains 'https:' or article_ld_image contains 'http:' -%}
      {%- assign article_ld_image = article_ld_image | replace_first: '//', 'https://' -%}
    {%- endunless -%}
  {%- endif -%}
{%- endif -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ article.title | json }},
    "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
    "dateModified": {{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
    "author": {
      "@type": "Person",
      "name": {{ article.author | default: shop.name | json }}
    },
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }}
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": {{ article_canonical | json }}
    }
    {%- if article_ld_image != blank -%}
      ,"image": [{{ article_ld_image | json }}]
    {%- endif -%}
    ,"description": {{ article.content | strip_html | truncate: 500 | json }}
  }
</script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": {{ 'general.breadcrumbs.home' | t | json }},
        "item": {{ shop.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }},
        "item": {{ request.origin | append: blog.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ article.title | json }},
        "item": {{ article_canonical | json }}
      }
    ]
  }
</script>

{% schema %}
{
  "name": "Article",
  "tag": "section",
  "class": "section-main-article"
}
{% endschema %}
