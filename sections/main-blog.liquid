<section class="section-padding">
  <div class="page-width" style="max-width: 42rem;">
    <header class="page-header">
      <h1>{{ blog.title }}</h1>
      {%- if blog.description != blank -%}
        <div class="rte" style="color: var(--color-muted);">{{ blog.description }}</div>
      {%- endif -%}
    </header>

    {%- paginate blog.articles by 6 -%}
      {%- for article in blog.articles -%}
        <article class="article-card">
          <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>
          <p style="font-size:0.9rem; color: var(--color-muted); margin:0 0 0.5rem;">{{ article.published_at | date: format: 'abbreviated_date' }}</p>
          {%- if article.excerpt_or_content != blank -%}
            <p style="margin:0;">{{ article.excerpt_or_content | strip_html | truncatewords: 36 }}</p>
          {%- endif -%}
          <a href="{{ article.url }}" style="display:inline-block; margin-top:0.75rem; font-weight:600;">{{ 'blogs.article.read_more_title' | t: title: article.title }}</a>
        </article>
      {%- endfor -%}

      {%- if paginate.pages > 1 -%}
        <nav style="margin-top:2rem; display:flex; gap:0.5rem; flex-wrap:wrap;" aria-label="{{ 'general.pagination.label' | t }}">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="btn btn--secondary">{{ paginate.previous.title }}</a>
          {%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="btn btn--secondary">{{ part.title }}</a>
            {%- else -%}
              <span class="btn btn--secondary" style="opacity:0.6;">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="btn btn--secondary">{{ paginate.next.title }}</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Blog",
  "tag": "section",
  "class": "section-main-blog"
}
{% endschema %}
