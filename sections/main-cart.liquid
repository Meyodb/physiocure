<section class="section-padding">
  <div class="page-width">
    <h1 class="page-header" style="margin-bottom:2rem;">{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count == 0 -%}
      <p>{{ 'cart.empty' | t }}</p>
      <p><a href="{{ routes.all_products_collection_url }}" class="btn" style="margin-top:1rem;">{{ 'general.continue_shopping' | t }}</a></p>
    {%- else -%}
      {% form 'cart', cart, class: 'cart-form' %}
        <div class="cart-layout">
          <div>
            <table class="cart-table" role="table">
              <caption class="visually-hidden">{{ 'cart.caption' | t }}</caption>
              <thead>
                <tr>
                  <th colspan="2">{{ 'cart.title' | t }}</th>
                  <th>{{ 'products.product.quantity.label' | t }}</th>
                  <th>{{ 'customer.order.total' | t }}</th>
                </tr>
              </thead>
              <tbody>
                {%- for item in cart.items -%}
                  <tr>
                    <td class="cart-item__image">
                      {% if item.image %}
                        <a href="{{ item.url }}">{{ item | image_url: width: 160 | image_tag: loading: 'lazy', alt: item.title }}</a>
                      {% endif %}
                    </td>
                    <td>
                      <a href="{{ item.url }}"><strong>{{ item.product.title }}</strong></a>
                      {%- unless item.product.has_only_default_variant -%}
                        <div style="font-size:0.9rem; color: var(--color-muted);">{{ item.variant.title }}</div>
                      {%- endunless -%}
                      <a href="{{ item.url_to_remove }}" style="font-size:0.85rem;">{{ 'cart.remove_title' | t: title: item.title }}</a>
                    </td>
                    <td>
                      <input
                        name="updates[]"
                        value="{{ item.quantity }}"
                        type="number"
                        min="0"
                        aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title }}"
                        style="max-width: 4rem; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.15);"
                      >
                    </td>
                    <td>{{ item.final_line_price | money }}</td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>

            <button type="submit" name="update" class="btn btn--secondary" style="margin-top:1rem;">
              Mettre à jour
            </button>

            {%- if section.settings.show_note -%}
              <div class="field" style="margin-top:1.5rem;">
                <label for="CartNote">{{ 'cart.note' | t }}</label>
                <textarea name="note" id="CartNote" rows="3">{{ cart.note }}</textarea>
              </div>
            {%- endif -%}
          </div>

          <div class="cart-summary">
            <p style="display:flex; justify-content:space-between; font-size:1.1rem;">
              <span>{{ 'cart.subtotal' | t }}</span>
              <strong>{{ cart.total_price | money }}</strong>
            </p>
            <p style="font-size:0.85rem; color: var(--color-muted); margin:0 0 1rem;">
              {{ section.settings.tax_text }}
            </p>
            <button type="submit" name="checkout" class="btn" style="width:100%;">
              {{ 'cart.checkout' | t }}
            </button>
            <a href="{{ routes.all_products_collection_url }}" style="display:block; text-align:center; margin-top:1rem;">{{ 'general.continue_shopping' | t }}</a>
          </div>
        </div>
      {% endform %}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Panier principal",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "Note de commande",
      "default": true
    },
    {
      "type": "text",
      "id": "tax_text",
      "label": "Texte sous le sous-total",
      "default": "Taxes et frais de livraison calculés à l’étape suivante."
    }
  ]
}
{% endschema %}
