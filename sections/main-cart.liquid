<section class="cart-page section-padding" data-cart-page>
  <div class="page-width">
    <header class="cart-page__intro">
      <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>
      {%- if cart.item_count > 0 -%}
        <p class="cart-page__meta">{{ 'cart.items_count' | t: count: cart.item_count }}</p>
      {%- endif -%}
    </header>

    {%- if cart.item_count == 0 -%}
      <div class="cart-empty">
        <p class="cart-empty__text">{{ 'cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn cart-empty__cta">{{ 'general.continue_shopping' | t }}</a>
      </div>
    {%- else -%}
      {% form 'cart', cart, class: 'cart-form cart-page__form', id: 'CartPageForm' %}
        <div class="cart-layout">
          <div class="cart-main">
            <div class="cart-items-panel">
              <div class="cart-items-panel__head" aria-hidden="true">
                <span class="cart-items-panel__col cart-items-panel__col--media"></span>
                <span class="cart-items-panel__col cart-items-panel__col--product">{{ 'cart.column_product' | t }}</span>
                <span class="cart-items-panel__col cart-items-panel__col--qty">{{ 'products.product.quantity.label' | t }}</span>
                <span class="cart-items-panel__col cart-items-panel__col--total">{{ 'customer.order.total' | t }}</span>
              </div>
              <ul class="cart-items" role="list">
                {%- for item in cart.items -%}
                  <li class="cart-item">
                    <div class="cart-item__body">
                      <a href="{{ item.url }}" class="cart-item__media" tabindex="-1" aria-hidden="true">
                        {%- if item.image -%}
                          {{ item | image_url: width: 200 | image_tag: loading: 'lazy', class: 'cart-item__img', alt: '' }}
                        {%- else -%}
                          <span class="cart-item__placeholder" aria-hidden="true"></span>
                        {%- endif -%}
                      </a>
                      <div class="cart-item__info">
                        <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                        {%- unless item.product.has_only_default_variant -%}
                          <p class="cart-item__variant">{{ item.variant.title }}</p>
                        {%- endunless -%}
                        <a
                          href="{{ item.url_to_remove }}"
                          class="cart-item__remove"
                          aria-label="{{ 'cart.remove_title' | t: title: item.title | escape }}"
                        >
                          {{ 'cart.remove' | t }}
                        </a>
                      </div>
                      <div class="cart-item__qty-block">
                        <label class="visually-hidden" for="CartQty-{{ forloop.index }}">
                          {{- 'products.product.quantity.input_label' | t: product: item.product.title -}}
                        </label>
                        <div class="cart-qty">
                          <input
                            id="CartQty-{{ forloop.index }}"
                            class="cart-qty__input"
                            name="updates[]"
                            value="{{ item.quantity }}"
                            type="number"
                            min="0"
                            inputmode="numeric"
                            data-cart-qty
                            aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title }}"
                          >
                        </div>
                      </div>
                      <div class="cart-item__line-total">
                        <span class="cart-item__line-label visually-hidden">{{ 'customer.order.total' | t }}</span>
                        <span class="cart-item__price">{{ item.final_line_price | money }}</span>
                      </div>
                    </div>
                  </li>
                {%- endfor -%}
              </ul>
            </div>

            <div class="cart-toolbar">
              <button type="submit" name="update" class="btn btn--secondary cart-toolbar__update" data-cart-update-btn>
                {{ 'cart.update' | t }}
              </button>
            </div>

            {%- if section.settings.show_note -%}
              <div class="cart-note field">
                <label class="cart-note__label" for="CartNote">{{ 'cart.note' | t }}</label>
                <textarea
                  class="cart-note__input"
                  name="note"
                  id="CartNote"
                  rows="2"
                  placeholder="{{ 'cart.note' | t }}"
                >{{ cart.note }}</textarea>
              </div>
            {%- endif -%}
          </div>

          <aside class="cart-summary" aria-labelledby="cart-summary-heading">
            <h2 id="cart-summary-heading" class="visually-hidden">{{ 'cart.subtotal' | t }}</h2>
            <div class="cart-summary__row">
              <span>{{ 'cart.subtotal' | t }}</span>
              <strong class="cart-summary__amount">{{ cart.total_price | money }}</strong>
            </div>
            <p class="cart-summary__legal">{{ section.settings.tax_text }}</p>
            <button type="submit" name="checkout" class="btn cart-summary__checkout">
              {{ 'cart.checkout' | t }}
            </button>
            <a href="{{ routes.all_products_collection_url }}" class="cart-summary__continue">{{ 'general.continue_shopping' | t }}</a>
          </aside>
        </div>
      {% endform %}

      <script>
        (function () {
          var form = document.getElementById('CartPageForm');
          if (!form) return;
          form.classList.add('cart-form--auto');
          var inputs = form.querySelectorAll('[data-cart-qty]');
          var updateBtn = form.querySelector('[data-cart-update-btn]');
          var t;
          function scheduleUpdate() {
            clearTimeout(t);
            t = setTimeout(function () {
              if (updateBtn) updateBtn.click();
            }, 450);
          }
          inputs.forEach(function (el) {
            el.addEventListener('change', scheduleUpdate);
          });
        })();
      </script>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Panier principal",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "Note de commande",
      "default": true
    },
    {
      "type": "text",
      "id": "tax_text",
      "label": "Texte sous le sous-total",
      "default": "Taxes et frais de livraison calculés à l’étape suivante."
    }
  ]
}
{% endschema %}
