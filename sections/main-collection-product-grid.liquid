<section class="section-padding">
  <div class="page-width">
    <header class="page-header">
      <h1>{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="rte" style="color: var(--color-muted); max-width: 42rem;">{{ collection.description }}</div>
      {%- endif -%}
    </header>

    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- if collection.products.size == 0 -%}
        <p>{{ 'collections.general.no_matches' | t }}</p>
      {%- else -%}
        <ul class="collection-grid" role="list">
          {%- for product in collection.products -%}
            <li>
              <article class="card-product">
                <a href="{{ product.url }}" class="card-product__media">
                  {%- if product.featured_media -%}
                    {%- assign card_alt = product.featured_media.alt | default: product.title -%}
                    {{ product.featured_media | image_url: width: 600 | image_tag: loading: 'lazy', alt: card_alt }}
                  {%- endif -%}
                </a>
                <div class="card-product__info">
                  <h2 class="card-product__title">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h2>
                  {% render 'price', product: product %}
                </div>
              </article>
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" style="margin-top:2rem; display:flex; gap:0.5rem; flex-wrap:wrap;" aria-label="{{ 'general.pagination.label' | t }}">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="btn btn--secondary">{{ paginate.previous.title }}</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="btn btn--secondary">{{ part.title }}</a>
              {%- else -%}
                <span class="btn btn--secondary" style="opacity:0.6; pointer-events:none;">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="btn btn--secondary">{{ paginate.next.title }}</a>
            {%- endif -%}
          </nav>
        {%- endif -%}

        {%- assign list_offset = paginate.current_page | minus: 1 | times: paginate.page_size -%}
        <script type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "ItemList",
            "name": {{ collection.title | json }},
            "numberOfItems": {{ collection.all_products_count | default: collection.products_count }},
            "itemListElement": [
              {%- assign list_first = true -%}
              {%- for product in collection.products -%}
                {%- unless list_first -%},{%- endunless -%}
                {
                  "@type": "ListItem",
                  "position": {{ list_offset | plus: forloop.index }},
                  "name": {{ product.title | json }},
                  "url": {{ request.origin | append: product.url | json }}
                }
                {%- assign list_first = false -%}
              {%- endfor -%}
            ]
          }
        </script>
        <script type="application/ld+json">
          {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
              {
                "@type": "ListItem",
                "position": 1,
                "name": {{ 'general.breadcrumbs.home' | t | json }},
                "item": {{ shop.url | json }}
              },
              {
                "@type": "ListItem",
                "position": 2,
                "name": {{ collection.title | json }},
                "item": {{ request.origin | append: collection.url | json }}
              }
            ]
          }
        </script>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Grille collection",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Produits par page"
    }
  ]
}
{% endschema %}
