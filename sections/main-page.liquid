<section class="section-padding">
  <div class="page-width" style="max-width: 48rem;">
    <header class="page-header">
      <h1>{{ page.title }}</h1>
    </header>
    <div class="rte">
      {{ page.content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page",
  "tag": "section",
  "class": "section-main-page"
}
{% endschema %}
