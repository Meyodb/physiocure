{%- comment -%}
  Page minimale : Shopify exige le formulaire « storefront_password » tant que la boutique
  est protégée par mot de passe. Pour ne plus voir cette page : Admin → Préférences en ligne → désactiver la protection.
{%- endcomment -%}
<div class="password-main password-main--minimal">
  <div class="password-card password-card--minimal">
    {% form 'storefront_password', class: 'password-form' %}
      {{ form.errors | default_errors }}
      <label for="Password" class="visually-hidden">Mot de passe boutique</label>
      <input
        type="password"
        name="password"
        id="Password"
        autocomplete="current-password"
        required
        placeholder="Mot de passe"
        class="password-card--minimal__input"
      >
      <button type="submit" class="btn password-card--minimal__btn">Entrer</button>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Accès boutique",
  "tag": "section",
  "class": "section-main-password",
  "settings": []
}
{% endschema %}
