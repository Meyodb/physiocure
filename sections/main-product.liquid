<section id="MainProduct" class="section-padding" data-section-type="product">
  <div class="page-width">
    <div class="grid-2 product-page-grid">
      <div class="product-media-stack">
        {%- if product.media.size > 0 -%}
          {%- assign primary_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media -%}
          <div style="border-radius: 16px; overflow: hidden; background: var(--color-surface); border: 1px solid rgba(0,0,0,0.06);">
            {{
              primary_media
              | image_url: width: 1400
              | image_tag:
                loading: 'eager',
                sizes: '(min-width: 900px) 45vw, 100vw',
                widths: '400, 600, 800, 1000, 1200, 1400',
                alt: primary_media.alt | default: product.title
            }}
          </div>
          {%- if product.media.size > 1 -%}
            <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(72px, 1fr)); gap:0.5rem; margin-top:0.75rem;">
              {%- for media in product.media limit: 8 -%}
                <a href="{{ media | image_url: width: 1400 }}" target="_blank" rel="noopener" style="border-radius:8px; overflow:hidden; aspect-ratio:1; border:1px solid rgba(0,0,0,0.08); display:block;">
                  {%- assign thumb_alt = media.alt | default: product.title -%}
                  {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: thumb_alt }}
                </a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>

      <div class="product-info-stack">
        {%- if section.settings.show_vendor and product.vendor != blank -%}
          <p style="margin:0 0 0.35rem; font-size:0.85rem; color: var(--color-muted);">{{ product.vendor }}</p>
        {%- endif -%}
        <h1 style="font-size: clamp(1.75rem, 4vw, 2.35rem);">{{ product.title }}</h1>
        <div style="margin: 1rem 0 1.5rem;">
          {% render 'price', product: product %}
        </div>

        {%- if product.description != blank -%}
          <div class="rte product-short-desc" style="color: var(--color-muted); margin-bottom:1.5rem;">
            {{ product.description | strip_html | truncatewords: 40 }}
          </div>
        {%- endif -%}

        {% capture product_form_id %}product-form-{{ section.id }}{% endcapture %}
        {% form 'product', product, class: 'product-form', id: product_form_id %}
          {%- unless product.has_only_default_variant -%}
            <div class="field">
              <label for="Variant-{{ section.id }}">Options</label>
              <select
                name="id"
                id="Variant-{{ section.id }}"
                data-main-variant-select
                class="variant-select"
              >
                {%- for variant in product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                    {% unless variant.available %}disabled{% endunless %}
                    data-url="{{ product.url }}?variant={{ variant.id }}"
                  >
                    {{ variant.title }} — {{ variant.price | money }}{% unless variant.available %} — {{ 'products.product.sold_out' | t }}{% endunless %}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endunless -%}

          <div class="field">
            <label for="Quantity-{{ section.id }}">{{ 'products.product.quantity.label' | t }}</label>
            <input
              type="number"
              id="Quantity-{{ section.id }}"
              name="quantity"
              value="1"
              min="1"
              style="max-width: 6rem;"
            >
          </div>

          <button
            type="submit"
            name="add"
            class="btn"
            style="width:100%; max-width: 22rem;"
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
          >
            {%- if product.selected_or_first_available_variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </button>
        {% endform %}

        <div style="margin-top:2rem; padding-top:1.5rem; border-top:1px solid rgba(0,0,0,0.08);" class="rte">
          {{ product.description }}
        </div>
      </div>
    </div>
  </div>
</section>

{%- assign ld_image = product.featured_media | image_url: width: 1200 -%}
{%- if ld_image contains '//' -%}
  {%- assign ld_image = ld_image | prepend: 'https:' -%}
{%- endif -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 500 | json }},
    "sku": {{ product.selected_or_first_available_variant.sku | json }},
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | default: shop.name | json }}
    },
    "image": {{ ld_image | json }},
    "offers": {
      "@type": "Offer",
      "url": {{ request.origin | append: product.url | json }},
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "price": {{ product.selected_or_first_available_variant.price | money_without_currency | strip | json }},
      "availability": "https://schema.org/{% if product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}"
    }
  }
</script>

{% schema %}
{
  "name": "Produit",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Afficher la marque (vendor)",
      "default": false
    }
  ]
}
{% endschema %}
