{%- liquid
  assign primary_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media
  assign current_variant = product.selected_or_first_available_variant
  assign review_blocks = section.blocks | where: 'type', 'review'
  assign step_blocks = section.blocks | where: 'type', 'step'
  assign carousel_blocks = section.blocks | where: 'type', 'carousel_slide'
  assign pack_blocks = section.blocks | where: 'type', 'pack_offer'
  assign use_pack_picker = false
  if section.settings.use_pack_cards and pack_blocks.size > 0 and product.has_only_default_variant == false
    assign use_pack_picker = true
  endif
  assign testimonials_layout = section.settings.testimonials_layout | default: 'grid'
  assign testimonials_heading = section.settings.testimonials_heading
  if testimonials_heading == blank
    assign testimonials_heading = section.settings.carousel_heading
  endif
  assign show_testimonial_grid = false
  assign show_testimonial_carousel = false
  if testimonials_layout == 'grid' and review_blocks.size > 0
    assign show_testimonial_grid = true
  elsif testimonials_layout == 'carousel' and carousel_blocks.size > 0
    assign show_testimonial_carousel = true
  endif
  assign visual_howto_blocks = section.blocks | where: 'type', 'visual_howto_step'
-%}

<section
  id="MainProduct"
  class="section-padding section-main-product product-layout-neuro"
  data-section-type="product"
  data-section-id="{{ section.id }}"
>
  <div class="page-width">
    <div class="product-neuro-top">
      {%- comment -%} Galerie (sticky) + lightbox {%- endcomment -%}
      <div class="product-neuro-gallery" data-product-gallery>
        {%- if product.media.size > 0 -%}
          <div class="product-neuro-gallery__main">
            <button
              type="button"
              class="product-neuro-gallery__main-btn"
              data-lightbox-open
              aria-label="{{ 'products.product.media.open_modal' | t }}"
            >
              {%- if primary_media.media_type == 'video' -%}
                {{
                  primary_media
                  | video_tag:
                    image_size: '1400x',
                    class: 'product-neuro-gallery__media product-neuro-gallery__media--video',
                    controls: true,
                    playsinline: true
                }}
              {%- elsif primary_media.media_type == 'external_video' -%}
                {{ primary_media | external_video_tag: class: 'product-neuro-gallery__media' }}
              {%- elsif primary_media.media_type == 'model' -%}
                {{ primary_media | model_viewer_tag: image_size: '1400x', reveal: 'interaction', toggleable: true }}
              {%- else -%}
                {%- assign main_image_id = 'ProductMainImg-' | append: section.id -%}
                {{
                  primary_media
                  | image_url: width: 1400
                  | image_tag:
                    loading: 'eager',
                    class: 'product-neuro-gallery__img',
                    id: main_image_id,
                    sizes: '(min-width: 900px) min(52vw, 640px), 100vw',
                    widths: '400, 600, 800, 1000, 1200, 1400',
                    alt: primary_media.alt | default: product.title
                }}
              {%- endif -%}
            </button>
          </div>

          {%- if product.media.size > 1 -%}
            <ul class="product-neuro-gallery__thumbs" role="list">
              {%- for media in product.media limit: 12 -%}
                <li role="listitem">
                  {%- assign thumb_src = media | image_url: width: 1400 -%}
                  {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                    {%- assign thumb_src = media.preview_image | image_url: width: 1400 -%}
                  {%- elsif media.media_type == 'model' -%}
                    {%- assign thumb_src = media.preview_image | image_url: width: 1400 -%}
                  {%- endif -%}
                  <button
                    type="button"
                    class="product-neuro-gallery__thumb{% if media == primary_media %} is-active{% endif %}"
                    data-gallery-thumb
                    data-full-src="{{ thumb_src }}"
                    data-media-type="{{ media.media_type }}"
                    aria-label="{{ 'products.product.media.open_media' | t: index: forloop.index }}"
                  >
                    {%- assign thumb_alt = media.alt | default: product.title -%}
                    {{ media.preview_image | default: media | image_url: width: 200 | image_tag: loading: 'lazy', alt: thumb_alt, class: 'product-neuro-gallery__thumb-img' }}
                  </button>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        {%- endif -%}

        <dialog class="product-neuro-lightbox" data-product-lightbox aria-label="{{ 'products.product.media.lightbox_label' | t }}">
          <div class="product-neuro-lightbox__inner">
            <button type="button" class="product-neuro-lightbox__close" data-lightbox-close aria-label="{{ 'products.product.media.close_modal' | t }}">
              <span aria-hidden="true">&times;</span>
            </button>
            <img src="{{ 'transparent.gif' | asset_url }}" alt="" class="product-neuro-lightbox__img" width="1200" height="1200" data-lightbox-img>
          </div>
        </dialog>
      </div>

      {%- comment -%} Colonne achat (style fiche neurocur) {%- endcomment -%}
      <div class="product-neuro-buy">
        {%- if section.settings.show_vendor and product.vendor != blank -%}
          <p class="product-neuro-buy__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product-neuro-buy__title">{{ product.title }}</h1>

        {%- if section.settings.usp_text != blank -%}
          <div class="product-neuro-buy__usp rte">{{ section.settings.usp_text }}</div>
        {%- endif -%}

        {%- if section.settings.benefits_list != blank -%}
          <ul class="product-neuro-benefits{% if section.settings.benefits_use_checks %} product-neuro-benefits--checks{% endif %}">
            {%- assign benefit_lines = section.settings.benefits_list | newline_to_br | split: '<br />' -%}
            {%- for line in benefit_lines -%}
              {%- assign line_clean = line | strip -%}
              {%- if line_clean != blank -%}
                <li class="product-neuro-benefits__item">{{ line_clean }}</li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- liquid
          assign show_urgency = false
          assign urgency_out = ''
          if section.settings.urgency_text != blank
            assign urgency_out = section.settings.urgency_text
            assign show_urgency = true
          elsif section.settings.show_low_stock_banner and current_variant.inventory_management and current_variant.inventory_quantity != nil
            if current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= section.settings.low_stock_threshold
              assign urgency_out = 'products.product.inventory_low_stock_show_count' | t: quantity: current_variant.inventory_quantity
              assign show_urgency = true
            endif
          endif
        -%}
        {%- if show_urgency -%}
          <p class="product-neuro-urgency{% if section.settings.urgency_use_dot %} product-neuro-urgency--dot{% endif %}">{{ urgency_out }}</p>
        {%- endif -%}

        {% capture product_form_id %}product-form-{{ section.id }}{% endcapture %}

        {%- if use_pack_picker and section.settings.pack_divider_text != blank -%}
          <p class="product-neuro-pack-divider" role="presentation">
            <span>{{ section.settings.pack_divider_text }}</span>
          </p>
        {%- endif -%}

        {%- if use_pack_picker -%}
          <div class="product-neuro-pack-form-wrap" data-product-pack-form>
            {% form 'product', product, class: 'product-neuro-form product-neuro-form--pack', id: product_form_id %}
            <input
              type="hidden"
              name="id"
              id="VariantId-{{ section.id }}"
              value="{{ current_variant.id }}"
              data-variant-input
            >
            {% render 'product-pack-picker', product: product, section: section, current_variant: current_variant, pack_blocks: pack_blocks %}

            {%- unless section.settings.hide_qty_pack_cards -%}
              <div class="field product-neuro-form__field product-neuro-form__qty-row">
                <label for="Quantity-{{ section.id }}">{{ 'products.product.quantity.label' | t }}</label>
                <input
                  type="number"
                  id="Quantity-{{ section.id }}"
                  name="quantity"
                  value="1"
                  min="1"
                  class="product-neuro-form__qty"
                >
              </div>
            {%- endunless -%}

            <button
              type="submit"
              name="add"
              class="btn product-neuro-form__submit product-neuro-form__submit--pack"
              data-pack-submit
              data-label-available="{{ 'products.product.add_to_cart' | t | escape }}"
              data-label-sold="{{ 'products.product.sold_out' | t | escape }}"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              {%- if current_variant.available -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ 'products.product.sold_out' | t }}
              {%- endif -%}
            </button>
            {% endform %}
          </div>
        {%- else -%}
          <div class="product-neuro-price-card">
            <div class="product-neuro-price-card__row">
              <div class="product-neuro-price-card__prices">
                {% render 'price', product: product, show_save_badge: true %}
              </div>
              {%- unless current_variant.available -%}
                <span class="product-neuro-badge product-neuro-badge--soldout">{{ 'products.product.sold_out' | t }}</span>
              {%- endunless -%}
            </div>

            {% form 'product', product, class: 'product-neuro-form', id: product_form_id %}
              {%- unless product.has_only_default_variant -%}
                <div class="field product-neuro-form__field">
                  <label for="Variant-{{ section.id }}">{{ 'products.product.variant_option_label' | t }}</label>
                  <select
                    name="id"
                    id="Variant-{{ section.id }}"
                    data-main-variant-select
                    class="variant-select"
                  >
                    {%- for variant in product.variants -%}
                      <option
                        value="{{ variant.id }}"
                        {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                        data-url="{{ product.url }}?variant={{ variant.id }}"
                      >
                        {{ variant.title }} — {{ variant.price | money }}{% unless variant.available %} — {{ 'products.product.sold_out' | t }}{% endunless %}
                      </option>
                    {%- endfor -%}
                  </select>
                </div>
              {%- else -%}
                <input type="hidden" name="id" value="{{ current_variant.id }}">
              {%- endunless -%}

              <div class="field product-neuro-form__field product-neuro-form__qty-row">
                <label for="Quantity-{{ section.id }}">{{ 'products.product.quantity.label' | t }}</label>
                <input
                  type="number"
                  id="Quantity-{{ section.id }}"
                  name="quantity"
                  value="1"
                  min="1"
                  class="product-neuro-form__qty"
                >
              </div>

              <button
                type="submit"
                name="add"
                class="btn product-neuro-form__submit"
                {% unless current_variant.available %}disabled{% endunless %}
              >
                {%- if current_variant.available -%}
                  {{ 'products.product.add_to_cart' | t }}
                {%- else -%}
                  {{ 'products.product.sold_out' | t }}
                {%- endif -%}
              </button>
            {% endform %}
          </div>
        {%- endif -%}

        {%- if section.settings.show_trust_bar -%}
          <ul class="product-neuro-trust" aria-label="{{ section.settings.trust_bar_label | escape }}">
            <li class="product-neuro-trust__item">
              <span class="product-neuro-trust__icon" aria-hidden="true">{{ section.settings.trust_icon_1 }}</span>
              <span class="product-neuro-trust__text">{{ section.settings.trust_text_1 }}</span>
            </li>
            <li class="product-neuro-trust__item">
              <span class="product-neuro-trust__icon" aria-hidden="true">{{ section.settings.trust_icon_2 }}</span>
              <span class="product-neuro-trust__text">{{ section.settings.trust_text_2 }}</span>
            </li>
            <li class="product-neuro-trust__item">
              <span class="product-neuro-trust__icon" aria-hidden="true">{{ section.settings.trust_icon_3 }}</span>
              <span class="product-neuro-trust__text">{{ section.settings.trust_text_3 }}</span>
            </li>
          </ul>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.show_sticky_bar -%}
      <div class="product-sticky-sentinel" data-product-sticky-sentinel aria-hidden="true"></div>
    {%- endif -%}

    {%- comment -%} Témoignages : grille OU carrousel (pas les deux) {%- endcomment -%}
    {%- if show_testimonial_grid -%}
      <div class="product-neuro-reviews">
        {%- if testimonials_heading != blank -%}
          <h2 class="product-neuro-reviews__heading">{{ testimonials_heading }}</h2>
        {%- endif -%}
        {%- for block in review_blocks -%}
          <blockquote class="product-neuro-review" {{ block.shopify_attributes }}>
            <div class="product-neuro-review__stars" aria-hidden="true">
              {%- assign r = block.settings.rating | default: 5 | at_most: 5 | at_least: 1 -%}
              {%- for i in (1..r) -%}★{%- endfor -%}
            </div>
            <p class="product-neuro-review__quote">{{ block.settings.quote }}</p>
            {%- if block.settings.author != blank -%}
              <footer class="product-neuro-review__author">{{ block.settings.author }}</footer>
            {%- endif -%}
          </blockquote>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Détails repliables + bandeau images {%- endcomment -%}
    {%- if product.description != blank -%}
      <details class="product-neuro-details" id="ProductDetails-{{ section.id }}">
        <summary class="product-neuro-details__summary">{{ section.settings.details_toggle_label }}</summary>
        <div class="product-neuro-details__body rte">
          {{ product.description }}
        </div>
      </details>
    {%- endif -%}

    {%- if product.media.size > 1 -%}
      <div class="product-neuro-strip-wrap">
        <div class="product-neuro-strip" role="list" aria-label="{{ section.settings.media_strip_label | escape }}">
          {%- for media in product.media -%}
            <div class="product-neuro-strip__cell" role="listitem">
              {{
                media.preview_image
                | default: media
                | image_url: width: 400
                | image_tag: loading: 'lazy', alt: media.alt | default: product.title, class: 'product-neuro-strip__img'
              }}
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if visual_howto_blocks.size > 0 -%}
      {% render 'howto-visual-steps',
        heading: section.settings.visual_howto_heading,
        blocks: visual_howto_blocks,
        section_id: section.id,
        fallback_ext: section.settings.visual_howto_fallback_ext
      %}
    {%- endif -%}

    {%- comment -%} Étapes texte seul (sans images) {%- endcomment -%}
    {%- if step_blocks.size > 0 -%}
      <section class="product-neuro-steps">
        {%- if section.settings.steps_heading != blank -%}
          <h2 class="product-neuro-steps__heading">{{ section.settings.steps_heading }}</h2>
        {%- endif -%}
        <ol class="product-neuro-steps__list">
          {%- for block in step_blocks -%}
            <li class="product-neuro-step" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <h3 class="product-neuro-step__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="product-neuro-step__text rte">{{ block.settings.text }}</div>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ol>
      </section>
    {%- endif -%}

    {%- if show_testimonial_carousel -%}
      <section class="product-neuro-carousel-section">
        {%- if testimonials_heading != blank -%}
          <h2 class="product-neuro-carousel-section__heading">{{ testimonials_heading }}</h2>
        {%- endif -%}
        <div class="product-neuro-carousel" data-product-carousel tabindex="0">
          {%- for block in carousel_blocks -%}
            <article class="product-neuro-carousel__slide" {{ block.shopify_attributes }}>
              <div class="product-neuro-carousel__stars" aria-hidden="true">
                {%- assign cr = block.settings.rating | default: 5 | at_most: 5 | at_least: 1 -%}
                {%- for i in (1..cr) -%}★{%- endfor -%}
              </div>
              {%- if block.settings.title != blank -%}
                <h3 class="product-neuro-carousel__title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.quote != blank -%}
                <p class="product-neuro-carousel__quote">{{ block.settings.quote }}</p>
              {%- endif -%}
              {%- if block.settings.author != blank -%}
                <p class="product-neuro-carousel__author">{{ block.settings.author }}</p>
              {%- endif -%}
            </article>
          {%- endfor -%}
        </div>
        <p class="product-neuro-carousel__hint visually-hidden">{{ 'products.product.carousel_scroll_hint' | t }}</p>
      </section>
    {%- endif -%}

    {%- comment -%}
      Blocs « texte » puis FAQ : les FAQ s’affichent après tous les blocs « section texte »,
      dans l’ordre des blocs FAQ dans l’éditeur (structure HTML toujours équilibrée).
    {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'content_row' -%}
        <section class="product-neuro-content-row" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h2 class="product-neuro-content-row__heading">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="product-neuro-content-row__body rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </section>
      {%- endif -%}
    {%- endfor -%}

    {%- assign faq_only = section.blocks | where: 'type', 'faq_item' -%}
    {%- if faq_only.size > 0 -%}
      {%- if section.settings.faq_heading != blank -%}
        <h2 class="product-neuro-faq__main-heading">{{ section.settings.faq_heading }}</h2>
      {%- endif -%}
      <div class="product-neuro-faq" data-product-faq>
        {%- for block in faq_only -%}
          <div class="product-neuro-faq__item" data-faq-item data-open="false" {{ block.shopify_attributes }}>
            <button type="button" class="product-neuro-faq__question" data-faq-toggle aria-expanded="false" id="FaqBtn-{{ block.id }}">
              {{ block.settings.question }}
              <span class="faq-chevron" aria-hidden="true">▼</span>
            </button>
            <div class="product-neuro-faq__answer rte" data-faq-body role="region" aria-labelledby="FaqBtn-{{ block.id }}">
              {{ block.settings.answer }}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Description longue en complément (si pas tout dans le toggle) {%- endcomment -%}
    {%- if section.settings.show_secondary_description and product.description != blank -%}
      <div class="product-description-full rte product-neuro-secondary-desc">
        {%- if section.settings.description_heading != blank -%}
          <h2 class="product-description-full__heading">{{ section.settings.description_heading }}</h2>
        {%- endif -%}
        {{ product.description }}
      </div>
    {%- endif -%}
  </div>

  {%- if section.settings.show_sticky_bar -%}
    {%- liquid
      assign sticky_cv = product.selected_or_first_available_variant
      assign sticky_on_sale = false
      if sticky_cv.compare_at_price > sticky_cv.price
        assign sticky_on_sale = true
      endif
      assign sticky_save_pct = 0
      if sticky_on_sale and sticky_cv.compare_at_price > 0
        assign sticky_save_pct = sticky_cv.compare_at_price | minus: sticky_cv.price | times: 100.0 | divided_by: sticky_cv.compare_at_price | round
      endif
      assign sticky_thumb = sticky_cv.featured_image | default: primary_media.preview_image | default: product.featured_image
      if sticky_thumb == blank and primary_media != blank
        assign sticky_thumb = primary_media.preview_image | default: primary_media
      endif
    -%}
    <div
      class="product-sticky-bar"
      data-product-sticky-bar
      data-save-label-fmt="{{ 'products.product.save_percent' | t: percent: '___PCT___' | escape }}"
      hidden
    >
      <div class="page-width product-sticky-bar__inner">
        <div class="product-sticky-bar__info">
          {%- if sticky_thumb != blank -%}
            {{
              sticky_thumb
              | image_url: width: 160
              | image_tag: loading: 'lazy', class: 'product-sticky-bar__thumb', alt: product.title
            }}
          {%- else -%}
            <span class="product-sticky-bar__thumb product-sticky-bar__thumb--placeholder" aria-hidden="true"></span>
          {%- endif -%}
          <div class="product-sticky-bar__text">
            <p class="product-sticky-bar__title">{{ product.title }}</p>
            <div
              class="price{% if sticky_on_sale %} price--on-sale{% endif %} product-sticky-bar__price"
              data-sticky-prices
            >
              <span class="price__sale-row">
                <span class="price__current product-sticky-bar__price-current" data-sticky-current>{{ sticky_cv.price | money }}</span>
                <span
                  class="price__compare product-sticky-bar__price-compare"
                  data-sticky-compare
                  {% unless sticky_on_sale %}
                    hidden
                  {% endunless %}
                >
                  {%- if sticky_on_sale -%}
                    {{- sticky_cv.compare_at_price | money -}}
                  {%- endif -%}
                </span>
                <span
                  class="price__save-badge product-sticky-bar__save"
                  data-sticky-save-badge
                  {% unless sticky_on_sale and sticky_save_pct > 0 %}
                    hidden
                  {% endunless %}
                >
                  {%- if sticky_on_sale and sticky_save_pct > 0 -%}
                    {{ 'products.product.save_percent' | t: percent: sticky_save_pct }}
                  {%- endif -%}
                </span>
              </span>
            </div>
          </div>
        </div>
        <button
          type="button"
          class="btn product-sticky-bar__cta"
          data-sticky-submit
          data-label-available="{{ 'products.product.add_to_cart' | t | escape }}"
          data-label-sold="{{ 'products.product.sold_out' | t | escape }}"
          {% if section.settings.sticky_bar_cta_label != blank %}
            data-label-custom="{{ section.settings.sticky_bar_cta_label | escape }}"
          {% endif %}
          {% unless sticky_cv.available %}
            disabled
          {% endunless %}
        >
          {%- if section.settings.sticky_bar_cta_label != blank -%}
            {{ section.settings.sticky_bar_cta_label }}
          {%- elsif sticky_cv.available -%}
            {{ 'products.product.add_to_cart' | t }}
          {%- else -%}
            {{ 'products.product.sold_out' | t }}
          {%- endif -%}
        </button>
      </div>
    </div>
  {%- endif -%}
</section>

{%- assign ld_image = product.featured_media | image_url: width: 1200 -%}
{%- if ld_image contains '//' -%}
  {%- assign ld_image = ld_image | prepend: 'https:' -%}
{%- endif -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 500 | json }},
    "sku": {{ current_variant.sku | json }},
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | default: shop.name | json }}
    },
    "image": {{ ld_image | json }},
    "offers": {
      "@type": "Offer",
      "url": {{ request.origin | append: product.url | json }},
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "price": {{ current_variant.price | money_without_currency | strip | json }},
      "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}"
    }
  }
</script>

{% schema %}
{
  "name": "Fiche produit landing",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_sticky_bar",
      "label": "Barre d’achat fixe en bas (mobile & desktop)",
      "default": true,
