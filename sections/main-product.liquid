<section id="MainProduct" class="section-padding section-main-product" data-section-type="product">
  <div class="page-width">
    <div class="grid-2 product-page-grid">
      <div class="product-media-stack">
        {%- if product.media.size > 0 -%}
          {%- assign primary_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media -%}
          <div class="product-gallery__main">
            {{
              primary_media
              | image_url: width: 1400
              | image_tag:
                loading: 'eager',
                class: 'product-gallery__img',
                sizes: '(min-width: 900px) min(52vw, 640px), 100vw',
                widths: '400, 600, 800, 1000, 1200, 1400',
                alt: primary_media.alt | default: product.title
            }}
          </div>
          {%- if product.media.size > 1 -%}
            <div class="product-gallery__thumbs" role="list">
              {%- for media in product.media limit: 8 -%}
                <a
                  href="{{ media | image_url: width: 1400 }}"
                  class="product-gallery__thumb{% if media == primary_media %} is-active{% endif %}"
                  target="_blank"
                  rel="noopener"
                  role="listitem"
                >
                  {%- assign thumb_alt = media.alt | default: product.title -%}
                  {{ media | image_url: width: 200 | image_tag: loading: 'lazy', alt: thumb_alt }}
                </a>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>

      <div class="product-info-stack product-buy-card">
        {%- if section.settings.show_vendor and product.vendor != blank -%}
          <p class="product-buy-card__vendor">{{ product.vendor }}</p>
        {%- endif -%}
        <h1 class="product-buy-card__title">{{ product.title }}</h1>
        <div class="product-buy-card__price">
          {% render 'price', product: product %}
        </div>

        {%- if product.description != blank -%}
          <p class="product-buy-card__excerpt">
            {{ product.description | strip_html | truncatewords: 42 }}
          </p>
        {%- endif -%}

        {% capture product_form_id %}product-form-{{ section.id }}{% endcapture %}
        {% form 'product', product, class: 'product-form', id: product_form_id %}
          {%- unless product.has_only_default_variant -%}
            <div class="field">
              <label for="Variant-{{ section.id }}">Options</label>
              <select
                name="id"
                id="Variant-{{ section.id }}"
                data-main-variant-select
                class="variant-select"
              >
                {%- for variant in product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                    {% unless variant.available %}disabled{% endunless %}
                    data-url="{{ product.url }}?variant={{ variant.id }}"
                  >
                    {{ variant.title }} — {{ variant.price | money }}{% unless variant.available %} — {{ 'products.product.sold_out' | t }}{% endunless %}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {%- endunless -%}

          <div class="field">
            <label for="Quantity-{{ section.id }}">{{ 'products.product.quantity.label' | t }}</label>
            <input
              type="number"
              id="Quantity-{{ section.id }}"
              name="quantity"
              value="1"
              min="1"
              class="product-buy-card__qty"
            >
          </div>

          <button
            type="submit"
            name="add"
            class="btn product-buy-card__submit"
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
          >
            {%- if product.selected_or_first_available_variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </button>
        {% endform %}

        {%- if section.settings.show_trust_bar -%}
          <ul class="product-trust-micro" aria-label="{{ section.settings.trust_bar_label | escape }}">
            <li>{{ section.settings.trust_text_1 }}</li>
            <li>{{ section.settings.trust_text_2 }}</li>
            <li>{{ section.settings.trust_text_3 }}</li>
          </ul>
        {%- endif -%}
      </div>
    </div>

    {%- if product.description != blank -%}
      <div class="product-description-full rte">
        {%- if section.settings.description_heading != blank -%}
          <h2 class="product-description-full__heading">{{ section.settings.description_heading }}</h2>
        {%- endif -%}
        {{ product.description }}
      </div>
    {%- endif -%}
  </div>
</section>

{%- assign ld_image = product.featured_media | image_url: width: 1200 -%}
{%- if ld_image contains '//' -%}
  {%- assign ld_image = ld_image | prepend: 'https:' -%}
{%- endif -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 500 | json }},
    "sku": {{ product.selected_or_first_available_variant.sku | json }},
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | default: shop.name | json }}
    },
    "image": {{ ld_image | json }},
    "offers": {
      "@type": "Offer",
      "url": {{ request.origin | append: product.url | json }},
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "price": {{ product.selected_or_first_available_variant.price | money_without_currency | strip | json }},
      "availability": "https://schema.org/{% if product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}"
    }
  }
</script>

{% schema %}
{
  "name": "Produit",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Afficher la marque (vendor)",
      "default": false
    },
    {
      "type": "text",
      "id": "description_heading",
      "label": "Titre au-dessus de la description détaillée",
      "default": "En savoir plus"
    },
    {
      "type": "checkbox",
      "id": "show_trust_bar",
      "label": "Afficher les repères de confiance sous le bouton",
      "default": true
    },
    {
      "type": "text",
      "id": "trust_bar_label",
      "label": "Libellé accessibilité (repères de confiance)",
      "default": "Avantages commande"
    },
    {
      "type": "text",
      "id": "trust_text_1",
      "label": "Repère 1",
      "default": "Livraison suivie"
    },
    {
      "type": "text",
      "id": "trust_text_2",
      "label": "Repère 2",
      "default": "Paiement sécurisé"
    },
    {
      "type": "text",
      "id": "trust_text_3",
      "label": "Repère 3",
      "default": "Service client réactif"
    }
  ]
}
{% endschema %}
