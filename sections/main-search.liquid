{%- comment -%}
  La recherche est désactivée : /search redirige vers l’accueil (lien de secours sans JS).
{%- endcomment -%}
<section class="section-padding">
  <div class="page-width visually-hidden">
    <p><a href="{{ routes.root_url }}">Retour à l’accueil</a></p>
  </div>
</section>
<script>
  window.location.replace({{ routes.root_url | json }});
</script>

{% schema %}
{
  "name": "Recherche (redirection)",
  "tag": "section",
  "class": "section-main-search"
}
{% endschema %}
