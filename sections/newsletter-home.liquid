<section class="section-padding" style="background: color-mix(in srgb, var(--color-accent) 12%, var(--color-bg));">
  <div class="page-width" style="text-align:center; max-width: 36rem;">
    {%- if section.settings.heading != blank -%}
      <h2 style="margin: 0 0 0.5rem; font-size: clamp(1.35rem, 3vw, 1.75rem);">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <p style="margin: 0 0 1.5rem; color: var(--color-muted);">{{ section.settings.text }}</p>
    {%- endif -%}
    {% form 'customer', class: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div style="display:flex; flex-wrap:wrap; gap:0.5rem; justify-content:center;">
        <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">{{ 'newsletter.label' | t }}</label>
        <input
          id="NewsletterEmail-{{ section.id }}"
          type="email"
          name="contact[email]"
          value="{{ form.email }}"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          placeholder="{{ 'newsletter.label' | t }}"
          required
          style="flex:1; min-width:220px; max-width:320px; padding:0.75rem 1rem; border-radius:999px; border:1px solid rgba(0,0,0,0.12);"
        >
        <button type="submit" class="btn" name="commit">{{ 'newsletter.button_label' | t }}</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p style="margin-top:1rem; color: var(--color-primary); font-weight:600;">{{ 'newsletter.success' | t }}</p>
      {%- endif -%}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Conseils bien-être & nouveautés"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte",
      "default": "Une à deux fois par mois, sans spam. Désinscription en un clic."
    }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
