{%- liquid
  assign trust_aria = section.settings.accessibility_label | strip
  if trust_aria == blank
    assign trust_aria = 'Nos engagements : livraison, paiement, SAV et transparence'
  endif
  assign marquee_seconds = section.settings.marquee_duration | default: 45 | plus: 0
  if marquee_seconds < 15
    assign marquee_seconds = 45
  endif
  assign respect_reduced_motion = section.settings.respect_reduced_motion
-%}
<section
  class="section-padding section-trust-strip trust-strip-marquee-section{% unless respect_reduced_motion %} trust-strip-marquee-section--force-auto-scroll{% endunless %}"
  style="--trust-marquee-duration: {{ marquee_seconds }}s; padding-block: clamp(1.5rem, 3.5vw, 2.5rem);"
  aria-label="{{ trust_aria | escape }}"
>
  <div class="page-width">
    {%- if section.blocks.size == 0 -%}
      <p class="trust-strip-marquee__empty">Ajoutez des éléments dans l’éditeur de thème.</p>
    {%- else -%}
    <div class="trust-strip-marquee">
      <div class="trust-strip-marquee__viewport">
        <div
          class="trust-strip-marquee__track"
          style="animation-duration: {{ marquee_seconds }}s;"
        >
          <ul class="trust-strip-marquee__list" role="list">
            {%- for block in section.blocks -%}
              <li class="trust-strip-marquee__item" {{ block.shopify_attributes }}>
                {%- if block.settings.emoji != blank -%}
                  <span class="trust-strip-marquee__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
                {%- endif -%}
                <span class="trust-strip-marquee__label">{{ block.settings.label }}</span>
                <span class="trust-strip-marquee__dash" aria-hidden="true">—</span>
                <span class="trust-strip-marquee__detail">{{ block.settings.detail }}</span>
              </li>
            {%- endfor -%}
          </ul>
          <ul class="trust-strip-marquee__list trust-strip-marquee__list--clone" role="presentation" aria-hidden="true">
            {%- for block in section.blocks -%}
              <li class="trust-strip-marquee__item">
                {%- if block.settings.emoji != blank -%}
                  <span class="trust-strip-marquee__emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
                {%- endif -%}
                <span class="trust-strip-marquee__label">{{ block.settings.label }}</span>
                <span class="trust-strip-marquee__dash" aria-hidden="true">—</span>
                <span class="trust-strip-marquee__detail">{{ block.settings.detail }}</span>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bandeau confiance",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "range",
      "id": "marquee_duration",
      "min": 20,
      "max": 90,
      "step": 5,
      "unit": "s",
      "label": "Durée d’un cycle de défilement",
      "default": 45
    },
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Libellé accessibilité (lecteurs d’écran)",
      "default": "Nos engagements : livraison, paiement, SAV et transparence"
    },
    {
      "type": "checkbox",
      "id": "respect_reduced_motion",
      "label": "Respecter « Réduire les animations » du navigateur",
      "default": false,
      "info": "Décoché (défaut) : défilement automatique pour tous. Coché : sans animation auto si le visiteur a activé moins d’animations (bandeau défilable au doigt)."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Élément",
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji (optionnel)",
          "default": "✨",
          "info": "Un seul caractère ou emoji affiché avant le libellé."
        },
        { "type": "text", "id": "label", "label": "Libellé court", "default": "Paiement blindé" },
        { "type": "text", "id": "detail", "label": "Détail", "default": "Transactions 100 % sécurisées" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bandeau confiance",
      "blocks": [
        { "type": "item", "settings": { "emoji": "📦", "label": "Expédition suivie", "detail": "Votre colis, du départ à la livraison" } },
        { "type": "item", "settings": { "emoji": "🔒", "label": "Paiement sécurisé", "detail": "Cryptage SSL & transactions protégées" } },
        { "type": "item", "settings": { "emoji": "💬", "label": "SAV réactif", "detail": "Une réponse sous 48 h ouvrées" } },
        { "type": "item", "settings": { "emoji": "🛡️", "label": "Transparence totale", "detail": "Retours simples, politique claire" } }
      ]
    }
  ]
}
{% endschema %}
