<section class="section-padding section-trust-strip" style="padding-block: clamp(1.5rem, 3.5vw, 2.5rem);">
  <div class="page-width">
    <ul class="trust-strip" role="list">
      {%- for block in section.blocks -%}
        <li {{ block.shopify_attributes }}><strong>{{ block.settings.label }}</strong> — {{ block.settings.detail }}</li>
      {%- endfor -%}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Bandeau confiance",
  "tag": "section",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "item",
      "name": "Élément",
      "settings": [
        { "type": "text", "id": "label", "label": "Libellé court", "default": "Paiement sécurisé" },
        { "type": "text", "id": "detail", "label": "Détail", "default": "Transactions chiffrées (SSL)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bandeau confiance",
      "blocks": [
        { "type": "item", "settings": { "label": "Livraison", "detail": "Suivi inclus" } },
        { "type": "item", "settings": { "label": "SAV", "detail": "Sous 48 h ouvrées" } },
        { "type": "item", "settings": { "label": "Transparence", "detail": "Retours & infos claires" } }
      ]
    }
  ]
}
{% endschema %}
