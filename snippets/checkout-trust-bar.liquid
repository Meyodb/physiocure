{%- comment -%} Barre de confiance CRO — affichée au-dessus du formulaire checkout (Plus / checkout.liquid). {%- endcomment -%}
<div class="pc-checkout-trust" role="region" aria-label="{{ 'physiocure.checkout_trust.aria' | t }}">
  <p class="pc-checkout-trust__headline">{{ 'physiocure.checkout_trust.headline' | t }}</p>
  <ul class="pc-checkout-trust__list">
    <li class="pc-checkout-trust__item">
      <span class="pc-checkout-trust__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </span>
      <span class="pc-checkout-trust__text">{{ 'physiocure.checkout_trust.secure' | t }}</span>
    </li>
    <li class="pc-checkout-trust__item">
      <span class="pc-checkout-trust__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      </span>
      <span class="pc-checkout-trust__text">{{ 'physiocure.checkout_trust.shipping' | t }}</span>
    </li>
    <li class="pc-checkout-trust__item">
      <span class="pc-checkout-trust__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </span>
      <span class="pc-checkout-trust__text">{{ 'physiocure.checkout_trust.guarantee' | t }}</span>
    </li>
  </ul>
</div>
