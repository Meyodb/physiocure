{%- comment -%}
  Comptes clients désactivés côté thème : redirection immédiate vers l’accueil.
{%- endcomment -%}
<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="robots" content="noindex, nofollow">
  <title>{{ shop.name }}</title>
  <meta http-equiv="refresh" content="0; url={{ routes.root_url }}">
</head>
<body style="margin:0;font-family:system-ui,sans-serif;padding:2rem;text-align:center;color:#333;">
  <p style="margin:0 0 1rem;">Redirection vers la boutique…</p>
  <p style="margin:0;">
    <a href="{{ routes.root_url }}" style="color:inherit;">Accéder à l’accueil</a>
  </p>
  <script>
    location.replace({{ routes.root_url | json }});
  </script>
</body>
</html>
