{%- liquid
  assign opt_idx = section.settings.pack_option_index | default: 1 | plus: 0
  if opt_idx < 1
    assign opt_idx = 1
  endif
  if opt_idx > 3
    assign opt_idx = 3
  endif
  assign v = current_variant
-%}
{%- if use_pack_qty_mode -%}
  <fieldset class="product-pack-cards" data-pack-picker data-pack-qty-mode>
    <legend class="visually-hidden">{{ 'products.product.pack_picker.legend' | t }}</legend>
    {%- for block in pack_blocks -%}
      {%- assign qty = block.settings.pack_quantity | default: 1 | plus: 0 -%}
      {%- if qty < 1 -%}
        {%- assign qty = 1 -%}
      {%- endif -%}
      {%- if qty > 10 -%}
        {%- assign qty = 10 -%}
      {%- endif -%}

      {%- assign line_price = v.price | times: qty -%}
      {%- assign price_cents_ov = block.settings.line_price_cents_override | default: 0 | plus: 0 -%}
      {%- if price_cents_ov > 0 -%}
        {%- assign line_price = price_cents_ov -%}
      {%- endif -%}

      {%- assign can_buy = v.available -%}
      {%- if can_buy and v.inventory_management and v.inventory_quantity != nil -%}
        {%- if qty > v.inventory_quantity -%}
          {%- assign can_buy = false -%}
        {%- endif -%}
      {%- endif -%}

      {%- assign card_selected = false -%}
      {%- if forloop.first -%}
        {%- assign card_selected = true -%}
      {%- endif -%}

      {%- assign sticky_img = v.featured_image | default: product.featured_media.preview_image | default: product.featured_image -%}

      {%- assign default_title = 'products.product.pack_picker.title_qty' | t: count: qty -%}
      {%- assign title_line = block.settings.card_title | default: default_title -%}
      {%- assign save_label = block.settings.savings_label | strip -%}

      <label
        class="product-pack-card{% if card_selected %} is-selected{% endif %}{% unless can_buy %} is-disabled{% endunless %}"
        data-pack-card
        {{ block.shopify_attributes }}
      >
        <input
          type="radio"
          name="product-pack-qty-{{ section.id }}"
          class="product-pack-card__input visually-hidden-focusable"
          value="{{ qty }}"
          data-pack-qty-radio
          data-variant-available="{{ can_buy }}"
          data-sticky-price="{{ line_price | money | escape }}"
          data-sticky-compare=""
          data-sticky-save-pct="0"
          data-sticky-image="{% if sticky_img != blank %}{{ sticky_img | image_url: width: 200 | escape }}{% endif %}"
          {% if card_selected %}
            checked
          {% endif %}
          {% unless can_buy %}
            disabled
          {% endunless %}
        >

        {%- assign ribbon_txt = block.settings.popular_badge | strip -%}
        {%- if ribbon_txt != blank -%}
          <span class="product-pack-card__ribbon" aria-hidden="true">{{ ribbon_txt }}</span>
        {%- endif -%}

        <span class="product-pack-card__shell">
          <span class="product-pack-card__header">
            <span class="product-pack-card__radio-ui" aria-hidden="true"></span>
            <span class="product-pack-card__head-text">
              <span class="product-pack-card__title-row">
                <strong class="product-pack-card__title">{{ title_line }}</strong>
                {%- if save_label != blank and block.settings.show_savings_badge -%}
                  <span class="product-pack-card__save-pill">{{ save_label }}</span>
                {%- endif -%}
              </span>
              {%- if block.settings.subtitle != blank -%}
                <span class="product-pack-card__subtitle">{{ block.settings.subtitle }}</span>
              {%- endif -%}
            </span>
            <span class="product-pack-card__price-col">
              <span class="product-pack-card__price-current">{{ line_price | money }}</span>
            </span>
          </span>

          {%- if block.settings.bundle_1_label != blank or block.settings.bundle_2_label != blank -%}
            <span class="product-pack-card__bundles">
              {%- if block.settings.bundle_1_label != blank -%}
                <span class="product-pack-card__bundle-row">
                  {%- if block.settings.bundle_1_image != blank -%}
                    {{
                      block.settings.bundle_1_image
                      | image_url: width: 120
                      | image_tag:
                        loading: 'lazy',
                        class: 'product-pack-card__bundle-thumb',
                        alt: block.settings.bundle_1_label
                    }}
                  {%- endif -%}
                  <span class="product-pack-card__bundle-meta">
                    <span class="product-pack-card__bundle-label">{{ block.settings.bundle_1_label }}</span>
                    {%- if block.settings.bundle_1_compare != blank -%}
                      <span class="product-pack-card__bundle-compare">{{ block.settings.bundle_1_compare }}</span>
                    {%- endif -%}
                  </span>
                </span>
              {%- endif -%}
              {%- if block.settings.bundle_2_label != blank -%}
                <span class="product-pack-card__bundle-row">
                  {%- if block.settings.bundle_2_image != blank -%}
                    {{
                      block.settings.bundle_2_image
                      | image_url: width: 120
                      | image_tag:
                        loading: 'lazy',
                        class: 'product-pack-card__bundle-thumb',
                        alt: block.settings.bundle_2_label
                    }}
                  {%- endif -%}
                  <span class="product-pack-card__bundle-meta">
                    <span class="product-pack-card__bundle-label">{{ block.settings.bundle_2_label }}</span>
                    {%- if block.settings.bundle_2_compare != blank -%}
                      <span class="product-pack-card__bundle-compare">{{ block.settings.bundle_2_compare }}</span>
                    {%- endif -%}
                  </span>
                </span>
              {%- endif -%}
            </span>
          {%- endif -%}
        </span>
      </label>
    {%- endfor -%}
  </fieldset>
{%- else -%}
  <fieldset class="product-pack-cards" data-pack-picker data-pack-option-index="{{ opt_idx }}">
    <legend class="visually-hidden">{{ 'products.product.pack_picker.legend' | t }}</legend>
    {%- for block in pack_blocks -%}
      {%- assign matched_variant = false -%}
      {%- assign match_val = block.settings.option_value | strip -%}
      {%- if match_val != blank -%}
        {%- for variant in product.variants -%}
          {%- assign vopt = variant.option1 -%}
          {%- if opt_idx == 2 -%}
            {%- assign vopt = variant.option2 -%}
          {%- elsif opt_idx == 3 -%}
            {%- assign vopt = variant.option3 -%}
          {%- endif -%}
          {%- if vopt == match_val -%}
            {%- assign matched_variant = variant -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      {%- if matched_variant == false -%}
        {%- continue -%}
      {%- endif -%}

      {%- assign v = matched_variant -%}
      {%- assign card_selected = false -%}
      {%- if v.id == current_variant.id -%}
        {%- assign card_selected = true -%}
      {%- endif -%}

      {%- assign card_price = v.price -%}
      {%- assign price_cents_ov = block.settings.line_price_cents_override | default: 0 | plus: 0 -%}
      {%- if price_cents_ov > 0 -%}
        {%- assign card_price = price_cents_ov -%}
      {%- endif -%}
      {%- assign sticky_img = v.featured_image | default: product.featured_media.preview_image | default: product.featured_image -%}

      {%- assign title_line = block.settings.card_title | default: v.title -%}
      {%- assign save_label = block.settings.savings_label | strip -%}

      <label
        class="product-pack-card{% if card_selected %} is-selected{% endif %}{% unless v.available %} is-disabled{% endunless %}"
        data-pack-card
        {{ block.shopify_attributes }}
      >
        <input
          type="radio"
          name="product-pack-variant-{{ section.id }}"
          class="product-pack-card__input visually-hidden-focusable"
          value="{{ v.id }}"
          data-pack-variant-radio
          data-variant-available="{{ v.available }}"
          data-sticky-price="{{ card_price | money | escape }}"
          data-sticky-compare=""
          data-sticky-save-pct="0"
          data-sticky-image="{% if sticky_img != blank %}{{ sticky_img | image_url: width: 200 | escape }}{% endif %}"
          {% if card_selected %}
            checked
          {% endif %}
          {% unless v.available %}
            disabled
          {% endunless %}
        >

        {%- assign ribbon_txt = block.settings.popular_badge | strip -%}
        {%- if ribbon_txt != blank -%}
          <span class="product-pack-card__ribbon" aria-hidden="true">{{ ribbon_txt }}</span>
        {%- endif -%}

        <span class="product-pack-card__shell">
          <span class="product-pack-card__header">
            <span class="product-pack-card__radio-ui" aria-hidden="true"></span>
            <span class="product-pack-card__head-text">
              <span class="product-pack-card__title-row">
                <strong class="product-pack-card__title">{{ title_line }}</strong>
                {%- if save_label != blank and block.settings.show_savings_badge -%}
                  <span class="product-pack-card__save-pill">{{ save_label }}</span>
                {%- endif -%}
              </span>
              {%- if block.settings.subtitle != blank -%}
                <span class="product-pack-card__subtitle">{{ block.settings.subtitle }}</span>
              {%- endif -%}
            </span>
            <span class="product-pack-card__price-col">
              <span class="product-pack-card__price-current">{{ card_price | money }}</span>
            </span>
          </span>

          {%- if block.settings.bundle_1_label != blank or block.settings.bundle_2_label != blank -%}
            <span class="product-pack-card__bundles">
              {%- if block.settings.bundle_1_label != blank -%}
                <span class="product-pack-card__bundle-row">
                  {%- if block.settings.bundle_1_image != blank -%}
                    {{
                      block.settings.bundle_1_image
                      | image_url: width: 120
                      | image_tag:
                        loading: 'lazy',
                        class: 'product-pack-card__bundle-thumb',
                        alt: block.settings.bundle_1_label
                    }}
                  {%- endif -%}
                  <span class="product-pack-card__bundle-meta">
                    <span class="product-pack-card__bundle-label">{{ block.settings.bundle_1_label }}</span>
                    {%- if block.settings.bundle_1_compare != blank -%}
                      <span class="product-pack-card__bundle-compare">{{ block.settings.bundle_1_compare }}</span>
                    {%- endif -%}
                  </span>
                </span>
              {%- endif -%}
              {%- if block.settings.bundle_2_label != blank -%}
                <span class="product-pack-card__bundle-row">
                  {%- if block.settings.bundle_2_image != blank -%}
                    {{
                      block.settings.bundle_2_image
                      | image_url: width: 120
                      | image_tag:
                        loading: 'lazy',
                        class: 'product-pack-card__bundle-thumb',
                        alt: block.settings.bundle_2_label
                    }}
                  {%- endif -%}
                  <span class="product-pack-card__bundle-meta">
                    <span class="product-pack-card__bundle-label">{{ block.settings.bundle_2_label }}</span>
                    {%- if block.settings.bundle_2_compare != blank -%}
                      <span class="product-pack-card__bundle-compare">{{ block.settings.bundle_2_compare }}</span>
                    {%- endif -%}
                  </span>
                </span>
              {%- endif -%}
            </span>
          {%- endif -%}
        </span>
      </label>
    {%- endfor -%}
  </fieldset>
{%- endif -%}
