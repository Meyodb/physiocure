<section class="section-padding">
  <div class="page-width" style="max-width: 42rem;">
    <h1>{{ 'customer.account.title' | t }}</h1>
    <p><a href="{{ routes.account_logout_url }}">Déconnexion</a></p>

    <h2 style="margin-top:2rem;">{{ 'customer.orders.title' | t }}</h2>
    {% paginate customer.orders by 10 %}
      {%- if customer.orders.size == 0 -%}
        <p>{{ 'customer.orders.none' | t }}</p>
      {%- else -%}
        <table class="cart-table">
          <thead>
            <tr>
              <th>{{ 'customer.orders.order_number' | t }}</th>
              <th>{{ 'customer.orders.date' | t }}</th>
              <th>{{ 'customer.orders.payment_status' | t }}</th>
              <th>{{ 'customer.orders.fulfillment_status' | t }}</th>
              <th>{{ 'customer.orders.total' | t }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for order in customer.orders -%}
              <tr>
                <td><a href="{{ order.url }}">{{ order.name }}</a></td>
                <td>{{ order.created_at | date: format: 'abbreviated_date' }}</td>
                <td>{{ order.financial_status_label }}</td>
                <td>{{ order.fulfillment_status_label }}</td>
                <td>{{ order.total_price | money }}</td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>
      {%- endif -%}
      {{ paginate | default_pagination }}
    {% endpaginate %}

    <h2 style="margin-top:2rem;">{{ 'customer.account.details' | t }}</h2>
    <p>{{ customer.name }}<br>{{ customer.email }}</p>
    <p><a href="{{ routes.account_addresses_url }}">{{ 'customer.account.view_addresses' | t }}</a></p>
  </div>
</section>
