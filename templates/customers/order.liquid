<section class="section-padding">
  <div class="page-width" style="max-width: 48rem;">
    <p><a href="{{ routes.account_url }}">{{ 'customer.account.return' | t }}</a></p>
    <h1>{{ 'customer.order.title' | t: name: order.name }}</h1>
    <p style="color: var(--color-muted);">{{ 'customer.order.date_html' | t: date: order.created_at | date: format: 'abbreviated_date' }}</p>

    {%- if order.cancelled -%}
      <p style="color:#b42318;">{{ 'customer.order.cancelled_html' | t: date: order.cancelled_at | date: format: 'abbreviated_date' }}</p>
      <p>{{ 'customer.order.cancelled_reason' | t: reason: order.cancel_reason_label }}</p>
    {%- endif -%}

    <div class="grid-2" style="margin-top:2rem;">
      <div>
        <h2 style="font-size:1rem;">{{ 'customer.order.billing_address' | t }}</h2>
        <div class="rte">{{ order.billing_address | format_address }}</div>
      </div>
      <div>
        <h2 style="font-size:1rem;">{{ 'customer.order.shipping_address' | t }}</h2>
        <div class="rte">{{ order.shipping_address | format_address }}</div>
      </div>
    </div>

    <h2 style="margin-top:2rem; font-size:1.1rem;">{{ 'cart.title' | t }}</h2>
    <table class="cart-table">
      <thead>
        <tr>
          <th>{{ 'customer.order.product' | t }}</th>
          <th>{{ 'customer.order.sku' | t }}</th>
          <th>{{ 'customer.order.price' | t }}</th>
          <th>{{ 'customer.order.quantity' | t }}</th>
          <th>{{ 'customer.order.total' | t }}</th>
        </tr>
      </thead>
      <tbody>
        {%- for line_item in order.line_items -%}
          <tr>
            <td>
              {%- if line_item.url != blank -%}
                <a href="{{ line_item.url }}">{{ line_item.title }}</a>
              {%- else -%}
                {{ line_item.title }}
              {%- endif -%}
              {%- unless line_item.selling_plan_allocation == nil -%}
                <div style="font-size:0.85rem; color: var(--color-muted);">{{ line_item.selling_plan_allocation.selling_plan.name }}</div>
              {%- endunless -%}
            </td>
            <td>{{ line_item.sku }}</td>
            <td>{{ line_item.price | money }}</td>
            <td>{{ line_item.quantity }}</td>
            <td>{{ line_item.final_line_price | money }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>

    <div style="max-width:22rem; margin-left:auto; margin-top:1.5rem;">
      <p style="display:flex; justify-content:space-between;"><span>{{ 'customer.order.subtotal' | t }}</span><span>{{ order.subtotal_price | money }}</span></p>
      {%- if order.total_discounts > 0 -%}
        <p style="display:flex; justify-content:space-between;"><span>{{ 'customer.order.discount' | t }}</span><span>-{{ order.total_discounts | money }}</span></p>
      {%- endif -%}
      {%- for shipping_method in order.shipping_methods -%}
        <p style="display:flex; justify-content:space-between;"><span>{{ 'customer.order.shipping' | t }} ({{ shipping_method.title }})</span><span>{{ shipping_method.price | money }}</span></p>
      {%- endfor -%}
      {%- if order.tax_lines.size > 0 -%}
        {%- for tax_line in order.tax_lines -%}
          <p style="display:flex; justify-content:space-between;"><span>{{ 'customer.order.tax' | t }} ({{ tax_line.title }} {{ tax_line.rate_percentage }}%)</span><span>{{ tax_line.price | money }}</span></p>
        {%- endfor -%}
      {%- elsif order.total_tax > 0 -%}
        <p style="display:flex; justify-content:space-between;"><span>{{ 'customer.order.tax' | t }}</span><span>{{ order.total_tax | money }}</span></p>
      {%- endif -%}
      <p style="display:flex; justify-content:space-between; font-weight:700; font-size:1.1rem; margin-top:0.5rem;"><span>{{ 'customer.order.total' | t }}</span><span>{{ order.total_price | money }}</span></p>
    </div>

    {%- assign first_fulfillment = order.line_items | map: 'fulfillment' | compact | first -%}
    {%- if first_fulfillment.tracking_urls.size > 0 -%}
      <p style="margin-top:1.5rem;">
        <a href="{{ first_fulfillment.tracking_urls.first }}" class="btn btn--secondary" target="_blank" rel="noopener">{{ 'customer.order.track_shipment' | t }}</a>
      </p>
    {%- endif -%}
  </div>
</section>
